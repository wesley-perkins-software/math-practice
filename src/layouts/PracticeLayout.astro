---
import BaseLayout from './BaseLayout.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  breadcrumb?: BreadcrumbItem[];
}

const { title, description, canonical, breadcrumb = [] } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Site Header -->
  <header class="border-b border-[#E2E8F0] bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-[#1E293B] hover:text-[#3B82F6] transition-colors">
        Math Practice
      </a>
      <nav class="hidden sm:flex items-center gap-5 text-sm font-medium text-[#64748B]">
        <a href="/addition-practice" class="hover:text-[#1E293B] transition-colors">Addition</a>
        <a href="/subtraction-practice" class="hover:text-[#1E293B] transition-colors">Subtraction</a>
        <a href="/multiplication-practice" class="hover:text-[#1E293B] transition-colors">Multiplication</a>
        <a href="/division-practice" class="hover:text-[#1E293B] transition-colors">Division</a>
        <a href="/arithmetic-speed-drill" class="hover:text-[#3B82F6] text-[#3B82F6] font-semibold transition-colors">Speed Drill</a>
      </nav>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <!-- Breadcrumb -->
    {breadcrumb.length > 0 && (
      <nav aria-label="Breadcrumb" class="mb-5 text-sm text-[#94A3B8] flex items-center flex-wrap gap-1">
        {breadcrumb.map((item, i) => (
          <>
            {i > 0 && <span aria-hidden="true">›</span>}
            {item.href ? (
              <a href={item.href} class="hover:text-[#3B82F6] transition-colors">{item.label}</a>
            ) : (
              <span class="text-[#64748B]">{item.label}</span>
            )}
          </>
        ))}
      </nav>
    )}

    <!-- H1 -->
    <slot name="h1" />

    <!-- Intro text -->
    <div class="mt-3 mb-6 text-[#64748B] text-base leading-relaxed max-w-xl">
      <slot name="intro" />
    </div>

    <!-- Practice Widget -->
    <slot name="widget" />

    <!-- Internal Links -->
    <slot name="links" />

    <!-- How it works section -->
    <slot name="how-it-works" />
  </main>

  <!-- Site Footer -->
  <footer class="border-t border-[#E2E8F0] mt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#94A3B8]">
        <a href="/" class="hover:text-[#64748B] transition-colors">Home</a>
        <a href="/math-practice" class="hover:text-[#64748B] transition-colors">Math Practice</a>
        <a href="/addition-practice" class="hover:text-[#64748B] transition-colors">Addition</a>
        <a href="/subtraction-practice" class="hover:text-[#64748B] transition-colors">Subtraction</a>
        <a href="/multiplication-practice" class="hover:text-[#64748B] transition-colors">Multiplication</a>
        <a href="/division-practice" class="hover:text-[#64748B] transition-colors">Division</a>
        <a href="/math-worksheets" class="hover:text-[#64748B] transition-colors">Worksheets</a>
      </div>
      <p class="text-xs text-[#CBD5E1] mt-4">© {new Date().getFullYear()} Math Practice. Free arithmetic practice for students of all ages.</p>
    </div>
  </footer>
</BaseLayout>
