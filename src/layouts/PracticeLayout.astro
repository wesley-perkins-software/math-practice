---
import BaseLayout from './BaseLayout.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  breadcrumb?: BreadcrumbItem[];
}

const { title, description, canonical, breadcrumb = [] } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <!-- Site Header -->
  <header class="bg-[#1E1B4B] sticky top-0 z-20 shadow-[0_1px_0_0_#312E81]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3.5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <span class="w-7 h-7 rounded-lg bg-[#4F46E5] flex items-center justify-center text-white font-black text-sm leading-none select-none group-hover:bg-[#6366F1] transition-colors">÷</span>
        <span class="text-base font-bold text-white tracking-tight">Math Practice</span>
      </a>
      <nav class="hidden sm:flex items-center gap-1">
        <a href="/addition-practice/1-digit" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Addition</a>
        <a href="/subtraction-practice" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Subtraction</a>
        <a href="/multiplication-practice" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Multiplication</a>
        <a href="/division-practice" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Division</a>
      </nav>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <!-- Breadcrumb -->
    {breadcrumb.length > 0 && (
      <nav aria-label="Breadcrumb" class="mb-5 text-sm text-[#A5B4FC] flex items-center flex-wrap gap-1">
        {breadcrumb.map((item, i) => (
          <>
            {i > 0 && <span aria-hidden="true" class="text-[#C7D2FE]/40">›</span>}
            {item.href ? (
              <a href={item.href} class="hover:text-[#4F46E5] transition-colors">{item.label}</a>
            ) : (
              <span class="text-[#6B7280]">{item.label}</span>
            )}
          </>
        ))}
      </nav>
    )}

    <!-- H1 -->
    <slot name="h1" />

    <!-- Intro text -->
    <div class="mt-3 mb-6 text-[#6B7280] text-base leading-relaxed max-w-xl">
      <slot name="intro" />
    </div>

    <!-- Practice Widget -->
    <slot name="widget" />

    <!-- Internal Links -->
    <slot name="links" />

    <!-- How it works section -->
    <slot name="how-it-works" />
  </main>

  <!-- Site Footer -->
  <footer class="border-t-2 border-[#E0E7FF] bg-[#EEF2FF] mt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#6366F1]">
        <a href="/" class="hover:text-[#3730A3] transition-colors">Home</a>
        <a href="/math-practice" class="hover:text-[#3730A3] transition-colors">Math Practice</a>
        <a href="/addition-practice/1-digit" class="hover:text-[#3730A3] transition-colors">Addition</a>
        <a href="/subtraction-practice" class="hover:text-[#3730A3] transition-colors">Subtraction</a>
        <a href="/multiplication-practice" class="hover:text-[#3730A3] transition-colors">Multiplication</a>
        <a href="/division-practice" class="hover:text-[#3730A3] transition-colors">Division</a>
        <a href="/math-worksheets" class="hover:text-[#3730A3] transition-colors">Worksheets</a>
      </div>
      <p class="text-xs text-[#A5B4FC] mt-4">© {new Date().getFullYear()} Math Practice. Free arithmetic practice for students of all ages.</p>
    </div>
  </footer>
</BaseLayout>
