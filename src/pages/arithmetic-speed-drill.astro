---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { ARITHMETIC_SPEED_DRILL } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/math-drills', label: 'Math Drills', description: 'Balanced mixed drill' },
  { href: '/mental-math-practice', label: 'Mental Math', description: 'Larger numbers' },
  { href: '/multiplication/facts', label: 'Multiplication Facts', description: 'Speed drill ×' },
  { href: '/math-facts-practice', label: 'Math Facts Practice', description: 'Focus on facts' },
];
---

<PracticeLayout
  title="Arithmetic Speed Drill — Beat the Clock with Mixed Math"
  description="How many arithmetic problems can you answer in 60 seconds? Mixed addition, subtraction, multiplication, and division. Track your best score."
  canonical={`${SITE}/arithmetic-speed-drill`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Arithmetic Speed Drill' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Arithmetic Speed Drill</h1>
  <div slot="intro">
    <p>60 seconds. How many can you get? The Speed Drill moves as fast as you do — answers clear almost instantly so nothing slows you down. It's the closest thing on this site to a pure reaction-speed arithmetic test.</p>
    <p class="mt-2">All four operations, facts up to 12×12. Your score is how many you answer correctly — try to beat your personal best each session.</p>
  </div>
  <PracticeWidget slot="widget" client:load config={ARITHMETIC_SPEED_DRILL} />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
