---
import PracticeLayout from '@/layouts/PracticeLayout.astro';

const SITE = 'https://www.mathpractice.com';
const EFFECTIVE_DATE = 'April 15, 2026';
---

<PracticeLayout
  title="Privacy Policy — Math Practice"
  description="Math Practice collects no personal information. Your progress data stays in your browser only. Read our full privacy policy."
  canonical={`${SITE}/privacy`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Privacy Policy' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Privacy Policy</h1>
  <p slot="intro">
    Your privacy matters. Here's exactly what we do — and don't — collect.
  </p>

  <div slot="links" class="space-y-8 text-sm text-[#374151] leading-relaxed max-w-xl">

    <p class="text-xs text-[#6B7280]">Effective date: {EFFECTIVE_DATE}</p>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">The short version</h2>
      <p>
        Math Practice does not collect, store, or transmit any personal information about you.
        We have no user accounts, no login, and no server-side data storage tied to individuals.
        The only data we use is stored locally in your own browser.
      </p>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">What data we store — and where</h2>
      <p>
        When you complete a practice session, your scores and stats are saved to your browser's
        <strong>localStorage</strong>. This data never leaves your device. We cannot see it, and
        it is not transmitted to any server. You can clear it at any time by clearing your browser's
        site data.
      </p>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">Cookies</h2>
      <p>
        Math Practice does not set any cookies. We do not use tracking cookies, advertising cookies,
        or session cookies.
      </p>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">Analytics</h2>
      <p>
        This policy will be updated if the analytics approach changes. Check the effective date at the
        top of this page for the most recent version.
      </p>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">Children's privacy (COPPA)</h2>
      <p>
        Math Practice is designed for use by children in K–5. We take children's privacy seriously.
        Because we collect no personal information whatsoever — no names, no email addresses,
        no account data — there is no risk of inadvertently collecting data from children under 13.
        Parents and guardians can clear the browser's localStorage at any time to erase all stored
        practice data.
      </p>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">Third-party services</h2>
      <p>
        This site is hosted on a third-party infrastructure provider. Their standard server logs may
        record anonymous request data (IP address, browser type, pages visited) as part of normal web
        server operation. We do not use this data for tracking individuals and it is subject to the
        hosting provider's own privacy practices.
      </p>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">Changes to this policy</h2>
      <p>
        If we make material changes to this privacy policy, we will update the effective date at the
        top of this page. We encourage you to review this page periodically.
      </p>
    </section>


  </div>
</PracticeLayout>
