---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { ADDITION_GENERAL } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/addition-practice/1-digit', label: '1-Digit Addition', description: 'Simple single-digit sums' },
  { href: '/addition-practice/2-digit', label: '2-Digit Addition', description: 'Two-digit numbers' },
  { href: '/addition-practice/2-digit-carrying', label: 'Addition with Carrying', description: 'Carrying and regrouping' },
  { href: '/subtraction-practice', label: 'Subtraction Practice', description: 'Practice subtraction next' },
  { href: '/math-drills', label: 'Math Drills', description: 'Mixed timed drills' },
  { href: '/arithmetic-speed-drill', label: 'Speed Drill', description: 'Beat the clock' },
];
---

<PracticeLayout
  title="Addition Practice — Free Online Addition Drills"
  description="Practice addition online with instant feedback. Choose 1-digit or 2-digit addition, with or without carrying. Timed and untimed modes."
  canonical={`${SITE}/addition-practice`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Addition Practice' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Addition Practice</h1>
  <div slot="intro">
    <p>Build your addition skills one problem at a time. Start with single-digit sums and work up to two-digit addition with carrying. Choose timed mode to challenge yourself, or untimed mode to work at your own pace.</p>
  </div>
  <PracticeWidget slot="widget" client:load config={ADDITION_GENERAL} />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
