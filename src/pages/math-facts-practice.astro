---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { MATH_FACTS_PRACTICE } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/multiplication/facts', label: 'Multiplication Facts', description: 'Just multiplication' },
  { href: '/division/facts', label: 'Division Facts', description: 'Just division' },
  { href: '/math-drills', label: 'Math Drills', description: 'All four operations' },
  { href: '/multiplication', label: 'Multiplication Practice', description: 'All multiplication levels' },
];
---

<PracticeLayout
  title="Math Facts Practice — Multiplication and Division Facts"
  description="Practice multiplication and division math facts online. Mixed × and ÷ problems up to 12×12. Timed and untimed modes with instant feedback."
  canonical={`${SITE}/math-facts-practice`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Math Facts Practice' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Math Facts Practice</h1>
  <div slot="intro">
    <p>Drill multiplication and division facts together in a single mixed session. Practicing the inverse relationship between × and ÷ helps facts stick faster and prepares you for more complex math.</p>
  </div>
  <PracticeWidget slot="widget" client:load config={MATH_FACTS_PRACTICE} />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
