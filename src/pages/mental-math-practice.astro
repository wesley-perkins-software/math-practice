---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { MENTAL_MATH } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/arithmetic-speed-drill', label: 'Arithmetic Speed Drill', description: 'All four operations, facts 1–12' },
  { href: '/math-drills', label: 'Math Drills', description: 'Deliberate practice — 2 minutes' },
  { href: '/addition/2-digit-with-carrying', label: '2-Digit Addition', description: 'Build two-digit fluency untimed' },
  { href: '/subtraction/2-digit-with-borrowing', label: '2-Digit Subtraction', description: 'Build two-digit fluency untimed' },
  { href: '/timed-drills', label: 'All Timed Drills', description: 'Compare all three drill formats' },
];

const faqItems = [
  {
    q: 'What is Mental Math Practice?',
    a: 'Mental Math Practice is a 60-second drill covering two-digit addition and subtraction with numbers up to 30. The goal is to calculate entirely in your head — no pencil and paper. It trains the mental arithmetic you use in everyday situations: calculating change, splitting a bill, estimating costs.',
  },
  {
    q: 'How is this different from Math Drills or the Speed Drill?',
    a: 'Math Drills and the Speed Drill cover all four operations within the standard facts range (1–12). Mental Math Practice focuses on addition and subtraction with larger two-digit numbers — the kind of mental calculation that requires strategies, not just memorized facts. It\'s a different skill: applied mental arithmetic rather than fact recall.',
  },
  {
    q: 'What grade level is Mental Math Practice for?',
    a: 'Grade 3 and above. Students should be comfortable with two-digit addition and subtraction before practicing at speed. If two-digit problems feel unfamiliar, use the untimed 2-digit addition and subtraction practice pages first.',
  },
  {
    q: 'What mental math strategies can I use?',
    a: 'Three common strategies: (1) Splitting — break numbers into tens and ones, then add each part separately (24 + 17 = 20 + 10 + 4 + 7 = 41). (2) Rounding and adjusting — round one number up to the nearest ten, compute, then subtract the adjustment (28 + 15 → 30 + 15 − 2 = 43). (3) Counting on — start from the larger number and count up by the smaller (38 + 5 → 39, 40, 41, 42, 43).',
  },
  {
    q: 'Is this free?',
    a: 'Yes. Mental Math Practice is completely free, requires no account, and works on any device — phone, tablet, or computer.',
  },
];
---

<PracticeLayout
  title="Mental Math Practice — Two-Digit Addition and Subtraction | Math Practice"
  description="60-second mental math drill with two-digit addition and subtraction, numbers up to 30. Build the mental arithmetic skills you use in everyday life. Free online practice with score tracking."
  canonical={`${SITE}/mental-math-practice`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Timed Drills', href: '/timed-drills' }, { label: 'Mental Math Practice' }]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": "Mental Math Practice",
      "description": "60-second mental math drill covering two-digit addition and subtraction with numbers up to 30. Builds applied mental arithmetic skills for everyday use.",
      "url": "https://www.mathpractice.com/mental-math-practice",
      "educationalLevel": ["Grade 3", "Grade 4", "Grade 5"],
      "teaches": "Mental Arithmetic",
      "provider": {
        "@type": "Organization",
        "name": "Math Practice",
        "url": "https://www.mathpractice.com"
      }
    })} />
  </Fragment>

  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Mental Math Practice</h1>
  <div slot="intro">
    <p>Practice the arithmetic you actually use in everyday life — adding and subtracting two-digit numbers entirely in your head. Problems use numbers up to 30. The goal is to calculate quickly without pencil and paper.</p>
    <p class="mt-2">Regular mental math practice builds number sense, sharpens estimation, and develops the calculation strategies that carry over into real-world problem solving.</p>
  </div>

  <PracticeWidget slot="widget" client:load config={MENTAL_MATH} />
  <InternalLinks slot="links" links={links} />

  <div slot="how-it-works" class="mt-12 space-y-10">
    <!-- What you'll practice -->
    <section aria-labelledby="hiw-heading">
      <h2 id="hiw-heading" class="text-lg font-semibold text-[#1E293B] mb-4">What You'll Practice</h2>
      <div class="bg-white border border-[#E2E8F0] rounded-2xl px-5 py-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs font-semibold text-[#6366F1] bg-[#EEF2FF] px-2.5 py-1 rounded-full uppercase tracking-wide">Grade 3–5</span>
          <span class="text-xs text-[#6B7280]">· 60 seconds · Addition & subtraction</span>
        </div>
        <ul class="text-sm text-[#4B5563] leading-relaxed space-y-1.5">
          <li>• Two-digit addition — numbers up to 30 (e.g., 24 + 17, 8 + 26)</li>
          <li>• Two-digit subtraction — numbers up to 30 (e.g., 31 − 15, 27 − 9)</li>
          <li>• Problems require mental strategies, not just memorized facts</li>
          <li>• 60-second timer — score is correct answers per minute</li>
          <li>• Personal best tracked automatically — no account needed</li>
        </ul>
      </div>
    </section>

    <!-- Mental math strategies -->
    <section aria-labelledby="strategies-heading">
      <h2 id="strategies-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Mental Math Strategies</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-white border border-[#E2E8F0] rounded-xl px-4 py-4">
          <p class="text-sm font-semibold text-[#1E293B] mb-1.5">Splitting</p>
          <p class="text-sm text-[#6B7280] leading-relaxed">Break both numbers into tens and ones. Add the tens, then the ones, then combine.</p>
          <p class="text-xs text-[#A5B4FC] font-mono mt-2">24 + 17<br />= 20+10 + 4+7<br />= 30 + 11 = 41</p>
        </div>
        <div class="bg-white border border-[#E2E8F0] rounded-xl px-4 py-4">
          <p class="text-sm font-semibold text-[#1E293B] mb-1.5">Round & Adjust</p>
          <p class="text-sm text-[#6B7280] leading-relaxed">Round one number to the nearest ten, compute, then add or subtract the difference.</p>
          <p class="text-xs text-[#A5B4FC] font-mono mt-2">28 + 15<br />→ 30 + 15 = 45<br />45 − 2 = 43</p>
        </div>
        <div class="bg-white border border-[#E2E8F0] rounded-xl px-4 py-4">
          <p class="text-sm font-semibold text-[#1E293B] mb-1.5">Count On</p>
          <p class="text-sm text-[#6B7280] leading-relaxed">Start from the larger number and count up by the smaller in chunks of tens then ones.</p>
          <p class="text-xs text-[#A5B4FC] font-mono mt-2">38 + 14<br />38 → 48 (+10)<br />48 → 52 (+4)</p>
        </div>
      </div>
    </section>

    <!-- Tips -->
    <section aria-labelledby="tips-heading">
      <h2 id="tips-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Tips for Parents and Teachers</h2>
      <div class="bg-[#EEF2FF] rounded-2xl px-5 py-5 text-sm text-[#4B5563] leading-relaxed space-y-3">
        <p>
          <strong>Build the foundation first.</strong> Students should be comfortable with <a href="/addition/2-digit-with-carrying" class="text-[#4F46E5] font-medium hover:underline">two-digit addition</a> and <a href="/subtraction/2-digit-with-borrowing" class="text-[#4F46E5] font-medium hover:underline">two-digit subtraction</a> before practicing at speed. If two-digit problems feel difficult, use the untimed practice pages first.
        </p>
        <p>
          <strong>Teach strategies explicitly.</strong> Mental math isn't guessing — it's applying a small set of reliable strategies quickly. Before running timed drills, walk students through splitting, rounding and adjusting, and counting on. Once they have a strategy toolkit, their speed will improve naturally.
        </p>
        <p>
          <strong>Connect to everyday situations.</strong> Mental math matters most in contexts like calculating change, estimating grocery totals, or splitting costs. Relating the drill to real situations motivates students and reinforces why the skill is worth practicing.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        {faqItems.map(({ q, a }) => (
          <div class="bg-white border border-[#E2E8F0] rounded-xl px-5 py-4">
            <h3 class="text-sm font-semibold text-[#1E293B] mb-1.5">{q}</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</PracticeLayout>
