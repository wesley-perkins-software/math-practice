---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import InternalLinks from '@/components/InternalLinks';

const SITE = 'https://mathpracticeonline.com';

const tables = Array.from({ length: 12 }, (_, i) => i + 1);

// Quick strategy summary per table for the grid cards
const STRATEGY: Record<number, string> = {
  1: 'Any number × 1 = itself. Zero memorization needed.',
  2: 'Double the number. 2×7 = 7+7 = 14.',
  3: 'Double, then add one more group. 3×7 = 14+7 = 21.',
  4: 'Double twice. 4×6 = double 6 = 12, double 12 = 24.',
  5: 'Always ends in 0 or 5. Count by fives.',
  6: '6×n = 5×n + n. For even n, product ends in same digit.',
  7: 'No shortcut — but use commutativity: 7×8 = 8×7.',
  8: 'Double three times. 8×7: 7→14→28→56.',
  9: 'Finger trick: fold finger n, count left for tens, right for ones.',
  10: 'Append a zero. 10×7 = 70.',
  11: 'Repeat the digit (1–9): 11×7=77. Exceptions: ×10, ×11, ×12.',
  12: '12×n = 10×n + 2×n. Combine ×10 rule with doubling.',
};

const relatedLinks = [
  { href: '/multiplication/facts', label: 'Mixed Multiplication Facts', description: 'All 144 facts from 1–12 in random order' },
  { href: '/division/facts', label: 'Division Facts', description: 'The inverse — practice ÷ alongside ×' },
  { href: '/math-worksheets/multiplication-worksheets', label: 'Multiplication Worksheets', description: 'Print randomized multiplication problems' },
  { href: '/multiplication', label: 'Multiplication Hub', description: 'All multiplication practice modes' },
];

const faqItems = [
  {
    q: 'What are the times tables 1–12?',
    a: 'The times tables 1–12 are the complete set of multiplication facts from 1×1=1 through 12×12=144. There are 144 unique fact combinations in total, though many are mirrors of each other (e.g., 7×8 = 8×7). Students are typically expected to know all 144 facts by the end of Grade 3.'
  },
  {
    q: 'Which times tables should I learn first?',
    a: 'Start with the easiest: the 1s (trivial), 2s (doubling), 5s (count by fives), and 10s (append a zero). These four tables cover a large portion of all facts and are the quickest to learn. Then move to the 3s, 4s, 9s (finger trick), 11s, and finally the hardest: 6s, 7s, 8s, and 12s.'
  },
  {
    q: 'What grade do students learn times tables?',
    a: 'Times table practice begins in Grade 2 with the 2s, 5s, and 10s. The full set (1×1 through 12×12) is the core Grade 3 fluency goal. Students are expected to recall all multiplication facts automatically by the end of 3rd grade. Grade 4 reinforces fluency and extends to multi-digit multiplication.'
  },
  {
    q: 'How long does it take to memorize the times tables?',
    a: 'With daily practice, most students can memorize all 12 times tables in 3–6 months. The key is consistent short sessions (5–10 minutes daily) rather than long occasional practice. Learning table-by-table, starting with the easiest, reduces the total load significantly since many hard facts become familiar before you reach them.'
  },
  {
    q: 'What is the hardest times table to memorize?',
    a: 'The 7s and 8s are typically the hardest because they lack intuitive patterns. The 6s, 7s, 8s, and 12s are the last four tables most students master. Focusing practice on these specific tables — especially 6×7, 6×8, 7×8 — closes the final gaps quickly.'
  },
];
---

<PracticeLayout
  title="Times Tables 1–12 — Practice Every Multiplication Table | Math Practice Online"
  description="Practice all 12 times tables with focused, table-by-table multiplication drills. Free online practice for 1× through 12× with instant feedback and strategy tips. Grade 2–4."
  canonical={`${SITE}/multiplication/times-tables`}
  breadcrumb={[
    { label: 'Home', href: '/' },
    { label: 'Multiplication', href: '/multiplication' },
    { label: 'Times Tables' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": "Times Tables 1–12 Practice",
      "description": "Free online practice for all 12 times tables. Focused table-by-table multiplication drills with instant feedback, strategy tips, and streak tracking for grades 2–4.",
      "url": `${SITE}/multiplication/times-tables`,
      "educationalLevel": ["Grade 2", "Grade 3", "Grade 4"],
      "teaches": "Multiplication times tables 1 through 12",
      "provider": { "@type": "Organization", "name": "Math Practice Online", "url": SITE }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
  </Fragment>

  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Times Tables 1–12</h1>
  <div slot="intro">
    <p>Practice every multiplication table from 1× through 12×. Each table has its own focused drill that presents all 12 facts in random order — the most effective way to build automatic recall. Choose a table below to start.</p>
  </div>

  <Fragment slot="links">
    <!-- Times table grid -->
    <section aria-labelledby="tables-grid-heading" class="mt-2">
      <h2 id="tables-grid-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Choose a Times Table</h2>
      <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
        {tables.map((n) => (
          <a
            href={`/multiplication/times-tables/${n}`}
            class="flex flex-col items-center bg-white border border-[#E2E8F0] rounded-2xl p-4 hover:border-[#059669] hover:shadow-md transition-all group"
          >
            <span class="text-2xl font-black text-[#059669] leading-none mb-1">{n}×</span>
            <span class="text-xs font-semibold text-[#1E293B] group-hover:text-[#059669] transition-colors mb-2">{n} Times Table</span>
            <span class="text-[10px] text-[#6B7280] text-center leading-tight">{STRATEGY[n]}</span>
          </a>
        ))}
      </div>
    </section>
  </Fragment>

  <Fragment slot="how-it-works">

    <!-- Learning order recommendation -->
    <section class="mt-12" aria-labelledby="order-heading">
      <h2 id="order-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Recommended Learning Order</h2>
      <div class="bg-white border border-[#E2E8F0] rounded-2xl overflow-hidden">
        <div class="divide-y divide-[#E2E8F0]">
          <div class="flex items-start gap-4 px-5 py-4">
            <span class="text-xs font-semibold text-[#059669] bg-[#ECFDF5] px-2 py-1 rounded-full shrink-0 mt-0.5">Start here</span>
            <div>
              <p class="text-sm font-medium text-[#1E293B]">×1, ×2, ×5, ×10 — The Easy Four</p>
              <p class="text-sm text-[#6B7280] mt-0.5">These four tables follow simple rules (identity, doubling, count-by-fives, append-zero) and are the fastest to master. Learn these first to build confidence and cover a large portion of all 144 facts immediately.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-5 py-4">
            <span class="text-xs font-semibold text-[#6366F1] bg-[#EEF2FF] px-2 py-1 rounded-full shrink-0 mt-0.5">Then</span>
            <div>
              <p class="text-sm font-medium text-[#1E293B]">×3, ×4, ×9, ×11 — Strategy Tables</p>
              <p class="text-sm text-[#6B7280] mt-0.5">Each of these has a reliable trick (3s = triple, 4s = double twice, 9s = finger trick, 11s = repeat the digit). With a good strategy, these can be learned quickly once the easy four are solid.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-5 py-4">
            <span class="text-xs font-semibold text-[#D97706] bg-[#FFFBEB] px-2 py-1 rounded-full shrink-0 mt-0.5">Finally</span>
            <div>
              <p class="text-sm font-medium text-[#1E293B]">×6, ×7, ×8, ×12 — The Hard Four</p>
              <p class="text-sm text-[#6B7280] mt-0.5">These require more deliberate memorization. But by the time you reach them, many facts are already known through commutativity. The final unknowns are just a handful: 6×7, 6×8, 7×8, and the ×12 facts.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Related links -->
    <section class="mt-12" aria-labelledby="related-heading">
      <h2 id="related-heading" class="text-base font-semibold text-[#1E293B] mb-3">Related Practice</h2>
      <InternalLinks client:load links={relatedLinks} />
    </section>

    <!-- FAQ -->
    <section class="mt-12" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        {faqItems.map(({ q, a }) => (
          <div class="bg-white border border-[#E2E8F0] rounded-xl px-5 py-4">
            <h3 class="text-sm font-semibold text-[#1E293B] mb-1.5">{q}</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </section>

  </Fragment>
</PracticeLayout>
