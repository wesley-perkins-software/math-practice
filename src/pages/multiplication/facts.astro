---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import MultiplicationPracticeHub from '@/components/MultiplicationPracticeHub';

const SITE = 'https://www.mathpractice.com';
---

<PracticeLayout
  title="Multiplication Facts Practice | Mixed Multiplication 1–12"
  description="Practice mixed multiplication facts from 1×1 to 12×12. Build multiplication fluency with instant feedback, streak tracking, and optional timed drills."
  canonical={`${SITE}/multiplication/facts`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Multiplication', href: '/multiplication' }, { label: 'Facts' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Multiplication Facts Practice</h1>
  <div slot="intro">
    <p>Practice mixed multiplication facts from 1 through 12 in random order. This broad mode helps students strengthen overall multiplication fluency across the entire fact family.</p>
    <p class="mt-2">Use untimed practice for accuracy first, then switch to timed mode to improve speed and automatic recall.</p>
  </div>
  <MultiplicationPracticeHub slot="widget" client:load active="facts" />

  <div slot="links" class="mt-10">
    <h2 class="text-base font-semibold text-[#1E293B] mb-3">What to Practice Next</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a
        href="/multiplication/times-tables/1"
        class="block bg-white border border-[#E2E8F0] rounded-xl p-4 hover:border-[#3B82F6] hover:shadow-sm transition-all"
      >
        <div class="font-semibold text-[#1E293B]">Times Tables</div>
        <div class="text-sm text-[#64748B] mt-0.5">Practice one table at a time (1–12)</div>
      </a>
      <a
        href="/division/facts"
        class="block bg-white border border-[#E2E8F0] rounded-xl p-4 hover:border-[#3B82F6] hover:shadow-sm transition-all"
      >
        <div class="font-semibold text-[#1E293B]">Division Practice</div>
        <div class="text-sm text-[#64748B] mt-0.5">Practice the inverse operation</div>
      </a>
    </div>
  </div>
</PracticeLayout>
