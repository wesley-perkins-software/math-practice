---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { MATH_DRILLS } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/arithmetic-speed-drill', label: 'Arithmetic Speed Drill', description: 'Max speed challenge' },
  { href: '/mental-math-practice', label: 'Mental Math Practice', description: 'Larger numbers' },
  { href: '/math-facts-practice', label: 'Math Facts Practice', description: 'Facts-focused drill' },
  { href: '/addition-practice', label: 'Addition Practice', description: 'Drill addition only' },
  { href: '/multiplication', label: 'Multiplication Practice', description: 'Drill multiplication only' },
];
---

<PracticeLayout
  title="Math Drills — Timed Mixed Arithmetic Practice"
  description="Fast-paced timed math drills covering all four operations. Answer as many arithmetic problems as you can in 60 seconds. Free online practice."
  canonical={`${SITE}/math-drills`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Math Drills' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Math Drills</h1>
  <div slot="intro">
    <p>Two minutes, all four operations. Math Drills is designed for deliberate practice — the longer session gives you time to think through each problem and learn from your mistakes. Wrong answers show the correct solution before moving on.</p>
    <p class="mt-2">Track your correct count and personal best each session. Use it daily to build arithmetic fluency across addition, subtraction, multiplication, and division.</p>
  </div>
  <PracticeWidget slot="widget" client:load config={MATH_DRILLS} />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
