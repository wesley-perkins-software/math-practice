---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { MATH_DRILLS } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/arithmetic-speed-drill', label: 'Arithmetic Speed Drill', description: 'Max speed challenge — 60 seconds' },
  { href: '/mental-math-practice', label: 'Mental Math Practice', description: 'Two-digit add & subtract' },
  { href: '/math-facts-practice', label: 'Math Facts Practice', description: 'Untimed mixed facts drill' },
  { href: '/multiplication/facts', label: 'Multiplication Facts', description: 'All 144 multiplication facts' },
  { href: '/timed-drills', label: 'All Timed Drills', description: 'Compare all three drill formats' },
];

const faqItems = [
  {
    q: 'What is Math Drills?',
    a: 'Math Drills is a two-minute timed practice session covering all four arithmetic operations — addition, subtraction, multiplication, and division — with numbers 1–12. After a wrong answer, the correct solution is shown before the next problem appears. This makes it a deliberate practice tool: you learn from mistakes in real time rather than just drilling through them.',
  },
  {
    q: 'What grade level is Math Drills for?',
    a: 'Math Drills is designed for Grade 2 and above. By Grade 2, students have typically learned addition and subtraction facts. Multiplication and division facts are usually introduced in Grade 3. Students who know all four operations will get the most from a mixed drill.',
  },
  {
    q: 'How is Math Drills different from the Arithmetic Speed Drill?',
    a: 'Math Drills runs for two minutes and shows the correct answer after each mistake. It\'s designed for deliberate practice — building fluency while still reinforcing what you don\'t know. The Speed Drill runs for 60 seconds with minimal delay between problems and no answer revealed for wrong responses. It\'s a pure speed test, not a learning tool.',
  },
  {
    q: 'How many problems will I answer in two minutes?',
    a: 'It depends on your fluency level. Beginners typically answer 20–30 problems per session. Students with strong fact fluency can reach 40–60 or more. Track your correct count across sessions to measure improvement over time.',
  },
  {
    q: 'Does it save my score?',
    a: 'Yes. Your correct count and personal best are saved automatically in your browser with no account required. Your best score is displayed at the start of each session.',
  },
];
---

<PracticeLayout
  title="Math Drills — Timed Mixed Arithmetic Practice | Math Practice"
  description="Two-minute timed math drills covering addition, subtraction, multiplication, and division facts 1–12. Wrong answers show the correct solution. Free online practice with score tracking."
  canonical={`${SITE}/math-drills`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Timed Drills', href: '/timed-drills' }, { label: 'Math Drills' }]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": "Math Drills",
      "description": "Two-minute timed arithmetic drill covering addition, subtraction, multiplication, and division facts 1–12. Wrong answers reveal the correct solution. Free with score tracking.",
      "url": "https://www.mathpractice.com/math-drills",
      "educationalLevel": ["Grade 2", "Grade 3", "Grade 4", "Grade 5"],
      "teaches": "Arithmetic Fluency",
      "provider": {
        "@type": "Organization",
        "name": "Math Practice",
        "url": "https://www.mathpractice.com"
      }
    })} />
  </Fragment>

  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Math Drills</h1>
  <div slot="intro">
    <p>Two minutes, all four operations. Math Drills is designed for deliberate practice — the longer session gives you time to think through each problem and learn from your mistakes. Wrong answers show the correct solution before moving on.</p>
    <p class="mt-2">Track your correct count and personal best each session. Use it daily to build arithmetic fluency across addition, subtraction, multiplication, and division.</p>
  </div>

  <PracticeWidget slot="widget" client:load config={MATH_DRILLS} />
  <InternalLinks slot="links" links={links} />

  <div slot="how-it-works" class="mt-12 space-y-10">
    <!-- What you'll practice -->
    <section aria-labelledby="hiw-heading">
      <h2 id="hiw-heading" class="text-lg font-semibold text-[#1E293B] mb-4">What You'll Practice</h2>
      <div class="bg-white border border-[#E2E8F0] rounded-2xl px-5 py-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs font-semibold text-[#6366F1] bg-[#EEF2FF] px-2.5 py-1 rounded-full uppercase tracking-wide">Grade 2–5</span>
          <span class="text-xs text-[#6B7280]">· 2 minutes · All four operations</span>
        </div>
        <ul class="text-sm text-[#4B5563] leading-relaxed space-y-1.5">
          <li>• Addition facts — sums through 12 + 12</li>
          <li>• Subtraction facts — paired with addition for fact families</li>
          <li>• Multiplication facts — all 144 facts from 1×1 through 12×12</li>
          <li>• Division facts — paired with multiplication, no remainders</li>
          <li>• Wrong answers show the correct solution before moving on</li>
          <li>• Personal best is tracked automatically — no account needed</li>
        </ul>
      </div>
    </section>

    <!-- Tips -->
    <section aria-labelledby="tips-heading">
      <h2 id="tips-heading" class="text-lg font-semibold text-[#1E293B] mb-4">How to Use Math Drills Effectively</h2>
      <div class="bg-[#EEF2FF] rounded-2xl px-5 py-5 text-sm text-[#4B5563] leading-relaxed space-y-3">
        <p>
          <strong>Run one session per day.</strong> Two minutes of focused practice each day builds fluency faster than occasional longer sessions. The goal is to make fact recall automatic — that happens through consistent repetition, not marathon drilling.
        </p>
        <p>
          <strong>Pay attention to the corrections.</strong> When a wrong answer shows the correct solution, don't just dismiss it. Those are the facts you haven't automated yet. Notice which operations slow you down — then use the untimed <a href="/multiplication/facts" class="text-[#4F46E5] font-medium hover:underline">multiplication facts</a> or <a href="/division/facts" class="text-[#4F46E5] font-medium hover:underline">division facts</a> practice to close those gaps.
        </p>
        <p>
          <strong>Graduate to the Speed Drill.</strong> Once your Math Drills score stops improving, try the <a href="/arithmetic-speed-drill" class="text-[#4F46E5] font-medium hover:underline">Arithmetic Speed Drill</a> — 60 seconds with faster transitions and no answer feedback. A high Speed Drill score means your facts are truly automated.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        {faqItems.map(({ q, a }) => (
          <div class="bg-white border border-[#E2E8F0] rounded-xl px-5 py-4">
            <h3 class="text-sm font-semibold text-[#1E293B] mb-1.5">{q}</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</PracticeLayout>
