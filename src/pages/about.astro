---
import PracticeLayout from '@/layouts/PracticeLayout.astro';

const SITE = 'https://www.mathpractice.com';
---

<PracticeLayout
  title="About — Math Practice"
  description="Math Practice is a free, no-account arithmetic practice site for K–5 students. Learn about our mission, what we offer, and how we protect student privacy."
  canonical={`${SITE}/about`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'About' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">About Math Practice</h1>
  <p slot="intro">
    Free arithmetic practice for students everywhere — no account, no ads, no cost.
  </p>

  <div slot="links" class="space-y-8 text-sm text-[#6B7280] leading-relaxed max-w-xl">

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">What is Math Practice?</h2>
      <p>
        Math Practice is a free website built to help K–5 students build fluency with the four core
        arithmetic operations: addition, subtraction, multiplication, and division. Every problem,
        every drill, and every worksheet on this site is free — always.
      </p>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">Who is it for?</h2>
      <ul class="list-disc list-inside space-y-1 mt-2">
        <li><strong>Students</strong> in kindergarten through 5th grade who want to sharpen their math facts</li>
        <li><strong>Parents</strong> looking for a safe, distraction-free practice tool at home</li>
        <li><strong>Teachers</strong> who need a quick warm-up activity or printable worksheets for the classroom</li>
      </ul>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">What does it offer?</h2>
      <ul class="list-disc list-inside space-y-1 mt-2">
        <li><strong>Addition, Subtraction, Multiplication, Division</strong> — practice at every difficulty level from 1-digit facts through 2-digit problems</li>
        <li><strong>Arithmetic Speed Drill</strong> — a 60-second challenge to build fluency under time pressure</li>
        <li><strong>Printable Worksheets</strong> — generate and print practice sheets for each operation</li>
        <li><strong>Progress Tracking</strong> — your stats are saved in your browser so you can see improvement over time</li>
        <li><strong>Grade-Level Guides</strong> — curated practice paths for 1st through 5th grade</li>
      </ul>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">Our philosophy</h2>
      <p>
        We believe every student deserves access to quality practice tools without barriers. There are
        no accounts to create, no subscriptions to manage, and no advertisements. Your progress is
        stored only in your own browser — we never see it, and it never leaves your device.
      </p>
    </section>

    <section>
      <h2 class="text-base font-semibold text-[#1E293B] mb-2">Get started</h2>
      <p>
        Jump in at the <a href="/" class="text-[#4F46E5] hover:underline">homepage</a> and pick
        any operation to begin. No sign-up needed.
      </p>
    </section>

  </div>
</PracticeLayout>
