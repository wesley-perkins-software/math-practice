---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { MULTIPLICATION_GENERAL } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/multiplication-practice/facts', label: 'Multiplication Facts', description: 'Times tables 1–12' },
  { href: '/multiplication-practice/1-12', label: 'Times Tables 1–12', description: 'Full 1–12 drill' },
  { href: '/division-practice', label: 'Division Practice', description: 'Practice the inverse' },
  { href: '/math-facts-practice', label: 'Math Facts Practice', description: 'Mixed facts drill' },
];
---

<PracticeLayout
  title="Multiplication Practice — Free Online Times Table Drills"
  description="Practice multiplication facts online. Times tables 1–12 with instant feedback, streaks, and timed modes. Free for students and parents."
  canonical={`${SITE}/multiplication-practice`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Multiplication Practice' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Multiplication Practice</h1>
  <div slot="intro">
    <p>Drill multiplication facts from 1×1 through 12×12. Build the automatic recall that makes harder math easier. Use timed mode to sharpen your speed.</p>
  </div>
  <PracticeWidget slot="widget" client:load config={MULTIPLICATION_GENERAL} />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
