---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import MultiplicationPracticeHub from '@/components/MultiplicationPracticeHub';

const SITE = 'https://www.mathpractice.com';
---

<PracticeLayout
  title="Multiplication Practice — Free Online Times Table Drills"
  description="Practice multiplication facts online. Times tables 1–12 with instant feedback, streaks, and timed modes. Free for students and parents."
  canonical={`${SITE}/multiplication-practice`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Multiplication Practice' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Multiplication Practice</h1>
  <div slot="intro">
    <p>Drill multiplication facts from 1×1 through 12×12. Choose a specific times table to master it, or switch to mixed practice for a full challenge.</p>
  </div>
  <MultiplicationPracticeHub slot="widget" client:load active="times-tables" />

  <div slot="links" class="mt-10">
    <h2 class="text-base font-semibold text-[#1E293B] mb-3">What to Practice Next</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a
        href="/division-practice"
        class="block bg-white border border-[#E2E8F0] rounded-xl p-4 hover:border-[#3B82F6] hover:shadow-sm transition-all"
      >
        <div class="font-semibold text-[#1E293B]">Division Practice</div>
        <div class="text-sm text-[#64748B] mt-0.5">Practice the inverse operation</div>
      </a>
      <a
        href="/math-facts-practice"
        class="block bg-white border border-[#E2E8F0] rounded-xl p-4 hover:border-[#3B82F6] hover:shadow-sm transition-all"
      >
        <div class="font-semibold text-[#1E293B]">Math Facts Practice</div>
        <div class="text-sm text-[#64748B] mt-0.5">Mixed × and ÷ facts drill</div>
      </a>
    </div>
  </div>
</PracticeLayout>
