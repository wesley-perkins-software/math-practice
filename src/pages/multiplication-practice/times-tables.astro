---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import MultiplicationPracticeHub from '@/components/MultiplicationPracticeHub';

const SITE = 'https://www.mathpractice.com';
---

<PracticeLayout
  title="Times Tables Practice 1–12 | Multiplication Drills"
  description="Practice individual times tables 1 through 12. Pick a number, drill it until it sticks. Instant feedback and streak tracking. Free."
  canonical={`${SITE}/multiplication-practice/times-tables`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Multiplication Practice', href: '/multiplication-practice' }, { label: 'Times Tables' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Times Tables Practice</h1>
  <div slot="intro">
    <p>Pick a number from 1–12 and drill that times table until it's automatic. When you're ready, switch to mixed practice to test them all.</p>
  </div>
  <MultiplicationPracticeHub slot="widget" client:load active="times-tables" />

  <div slot="links" class="mt-10">
    <h2 class="text-base font-semibold text-[#1E293B] mb-3">What to Practice Next</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a
        href="/multiplication-practice/mixed"
        class="block bg-white border border-[#E2E8F0] rounded-xl p-4 hover:border-[#3B82F6] hover:shadow-sm transition-all"
      >
        <div class="font-semibold text-[#1E293B]">Mixed Practice</div>
        <div class="text-sm text-[#64748B] mt-0.5">All facts 1–12 randomly mixed</div>
      </a>
      <a
        href="/division-practice"
        class="block bg-white border border-[#E2E8F0] rounded-xl p-4 hover:border-[#3B82F6] hover:shadow-sm transition-all"
      >
        <div class="font-semibold text-[#1E293B]">Division Practice</div>
        <div class="text-sm text-[#64748B] mt-0.5">Practice the inverse operation</div>
      </a>
    </div>
  </div>
</PracticeLayout>
