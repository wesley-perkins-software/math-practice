---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { MULTIPLICATION_FACTS } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/multiplication-practice/1-12', label: 'Times Tables 1–12', description: 'Full table drill' },
  { href: '/division-practice/facts', label: 'Division Facts', description: 'Practice the inverse' },
  { href: '/math-facts-practice', label: 'Math Facts Practice', description: 'Mixed × and ÷ facts' },
  { href: '/multiplication-practice', label: 'All Multiplication Practice', description: 'See all levels' },
];
---

<PracticeLayout
  title="Multiplication Facts Practice | Times Tables 1–12"
  description="Practice all 144 multiplication facts (1–12 times tables) online. Instant feedback, timed drills, and streak tracking. Free."
  canonical={`${SITE}/multiplication-practice/facts`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Multiplication Practice', href: '/multiplication-practice' }, { label: 'Multiplication Facts' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Multiplication Facts Practice</h1>
  <div slot="intro">
    <p>Practice all 144 multiplication facts from 1×1 to 12×12. Random problems across the full times table ensure you strengthen every fact, not just the easy ones.</p>
    <p class="mt-2">Timed mode is perfect for building the automatic recall needed for higher math.</p>
  </div>
  <PracticeWidget slot="widget" client:load config={MULTIPLICATION_FACTS} />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
