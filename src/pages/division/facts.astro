---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import DivisionPracticeHub from '@/components/DivisionPracticeHub';
import InternalLinks from '@/components/InternalLinks';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/division/divide-by/2', label: 'Divide by 2 Practice', description: 'Build fluency with one divisor' },
  { href: '/division/divide-by/6', label: 'Divide by 6 Practice', description: 'Target one fact family' },
  { href: '/division/remainders', label: 'Division with Remainders', description: 'Quotient plus remainder' },
  { href: '/math-facts-practice', label: 'Math Facts Practice', description: 'Mixed multiplication and division facts' },
];
---

<PracticeLayout
  title="Division Facts Practice"
  description="Practice basic division facts 1–12 with exact whole-number answers. Build speed, accuracy, and confidence with clean division fact drills."
  canonical={`${SITE}/division/facts`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Division' }, { label: 'Facts' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Division Facts Practice</h1>
  <div slot="intro">
    <p>Practice mixed exact division problems across facts 1–12. Every problem divides evenly so you can reinforce core division facts, improve recall speed, and build a strong base for more advanced division.</p>
  </div>
  <DivisionPracticeHub slot="widget" active="facts" client:load />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
