---
import BaseLayout from '@/layouts/BaseLayout.astro';
import InternalLinks from '@/components/InternalLinks';

const SITE = 'https://www.mathpractice.com';

const modes = [
  {
    href: '/division/divide-by/1',
    label: 'Divide by One Number',
    grade: 'Grade 3 – Grade 4',
    description: 'Focus on one divisor at a time (÷1 through ÷12). Great for targeted practice and fact-family mastery.',
    symbol: '÷ 8',
  },
  {
    href: '/division/facts',
    label: 'Division Facts',
    grade: 'Grade 3',
    description: 'Practice exact division facts from 1÷1 through 144÷12. Build fast recall for core fact families.',
    symbol: '56 ÷ 7',
  },
  {
    href: '/division/remainders',
    label: 'Division with Remainders',
    grade: 'Grade 3 – Grade 4',
    description: 'Solve division problems where the quotient is not exact. Build confidence interpreting quotient + remainder.',
    symbol: '29 ÷ 6',
  },
];

const relatedLinks = [
  { href: '/multiplication/facts', label: 'Multiplication Facts Practice', description: 'Strong times tables make division much easier' },
  { href: '/multiplication', label: 'Multiplication Practice', description: 'Need a refresher? Practice multiplication first' },
  { href: '/math-worksheets/division-worksheets', label: 'Division Worksheets', description: 'Print extra division pages with and without remainders' },
  { href: '/math-facts-practice', label: 'Math Facts Practice', description: 'Mix multiplication and division in one practice set' },
];

const faqItems = [
  {
    q: 'What grade level is division?',
    a: 'Division is typically introduced in Grade 3 alongside multiplication fact families. Grade 4 continues with larger numbers, remainders, and more complex division strategies.',
  },
  {
    q: 'Should students learn multiplication before division?',
    a: 'Yes. Multiplication and division are inverse operations, and strong multiplication fact fluency makes division much easier. Students usually learn both together, but multiplication facts are the foundation.',
  },
  {
    q: 'What is a remainder in division?',
    a: 'A remainder is what is left over when a number cannot be divided equally into full groups. For example, 29 ÷ 6 = 4 remainder 5, because 6 fits into 29 four times (24) with 5 left.',
  },
  {
    q: 'What is the best order to teach division?',
    a: 'Start with exact division facts (no remainders), then practice one divisor at a time, and finally move to mixed division with remainders. This progression builds confidence before introducing extra complexity.',
  },
  {
    q: 'How does this division practice work?',
    a: 'Practice runs continuously with instant right/wrong feedback on every answer. Scores, streaks, and best sessions are saved automatically in your browser.',
  },
];
---

<BaseLayout
  title="Division Practice — Free Online Division Drills | Math Practice"
  description="Free online division practice for grades 3–4. Practice exact division facts, division with remainders, and divide-by-one-number drills. Instant feedback and streak tracking."
  canonical={`${SITE}/division`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.mathpractice.com/" },
        { "@type": "ListItem", "position": 2, "name": "Division Practice" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": "Division Practice",
      "description": "Free online division practice for grades 3–4 covering division facts, divide-by drills, and division with remainders. Instant feedback and progress tracking.",
      "url": "https://www.mathpractice.com/division",
      "educationalLevel": ["Grade 3", "Grade 4"],
      "teaches": "Division",
      "provider": {
        "@type": "Organization",
        "name": "Math Practice",
        "url": "https://www.mathpractice.com"
      }
    })} />
  </Fragment>

  <header class="bg-[#1E1B4B] sticky top-0 z-20 shadow-[0_1px_0_0_#312E81]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3.5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <span class="w-7 h-7 rounded-lg bg-[#4F46E5] flex items-center justify-center text-white font-black text-sm leading-none select-none group-hover:bg-[#6366F1] transition-colors">÷</span>
        <span class="text-base font-bold text-white tracking-tight">Math Practice</span>
      </a>
      <nav class="hidden sm:flex items-center gap-1">
        <a href="/addition" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Addition</a>
        <a href="/subtraction" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Subtraction</a>
        <a href="/multiplication" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Multiplication</a>
        <a href="/division" class="px-3 py-1.5 rounded-lg text-sm font-medium text-white bg-white/10 transition-all">Division</a>
      </nav>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <nav aria-label="Breadcrumb" class="mb-5 text-sm text-[#A5B4FC] flex items-center flex-wrap gap-1">
      <a href="/" class="hover:text-[#4F46E5] transition-colors">Home</a>
      <span aria-hidden="true" class="text-[#C7D2FE]/40">›</span>
      <span class="text-[#6B7280]">Division Practice</span>
    </nav>

    <h1 class="text-3xl font-bold text-[#1E293B]">Division Practice</h1>
    <p class="mt-3 mb-8 text-[#6B7280] text-base leading-relaxed max-w-xl">
      Free online division practice for grades 3–4. Choose a mode below to practice exact facts, targeted divide-by drills, or division with remainders.
    </p>

    <section aria-labelledby="modes-heading">
      <h2 id="modes-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Choose a Practice Mode</h2>
      <div class="flex flex-col gap-4">
        {modes.map((m) => (
          <a
            href={m.href}
            class="flex items-start gap-4 bg-white border border-[#E2E8F0] rounded-2xl p-5 hover:border-[#4F46E5] hover:shadow-md transition-all group"
          >
            <div class="w-16 h-14 rounded-xl bg-[#EEF2FF] flex items-center justify-center font-mono text-sm font-bold text-[#4F46E5] shrink-0 leading-tight text-center">
              {m.symbol}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline gap-2 flex-wrap">
                <span class="font-semibold text-[#1E293B] group-hover:text-[#4F46E5] transition-colors">{m.label}</span>
                <span class="text-xs font-medium text-[#6366F1] bg-[#EEF2FF] px-2 py-0.5 rounded-full">{m.grade}</span>
              </div>
              <p class="text-sm text-[#6B7280] mt-1 leading-relaxed">{m.description}</p>
            </div>
            <span class="text-[#A5B4FC] group-hover:text-[#4F46E5] transition-colors text-lg leading-none mt-1" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>

    <section class="mt-12" aria-labelledby="progression-heading">
      <h2 id="progression-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Grade-by-Grade Progression</h2>
      <div class="bg-white border border-[#E2E8F0] rounded-2xl overflow-hidden">
        <div class="divide-y divide-[#E2E8F0]">
          <div class="flex items-start gap-4 px-5 py-4">
            <span class="w-20 text-xs font-semibold text-[#6366F1] uppercase tracking-wide pt-0.5 shrink-0">Grade 3</span>
            <div>
              <p class="text-sm font-medium text-[#1E293B]">Division Facts and Equal Groups</p>
              <p class="text-sm text-[#6B7280] mt-0.5">Learn division as sharing and grouping. Build fluency with exact facts and connect each fact to multiplication families.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-5 py-4">
            <span class="w-20 text-xs font-semibold text-[#6366F1] uppercase tracking-wide pt-0.5 shrink-0">Grade 4</span>
            <div>
              <p class="text-sm font-medium text-[#1E293B]">Division with Remainders</p>
              <p class="text-sm text-[#6B7280] mt-0.5">Extend fluency to non-exact division. Interpret quotients and remainders and apply division to multi-step word problems.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-5 py-4">
            <span class="w-20 text-xs font-semibold text-[#6366F1] uppercase tracking-wide pt-0.5 shrink-0">Grade 5</span>
            <div>
              <p class="text-sm font-medium text-[#1E293B]">Long Division Readiness</p>
              <p class="text-sm text-[#6B7280] mt-0.5">Strong fact recall and remainder understanding support long division, fractions, and ratio work in upper elementary math.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-12" aria-labelledby="tips-heading">
      <h2 id="tips-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Tips for Parents and Teachers</h2>
      <div class="bg-[#EEF2FF] rounded-2xl px-5 py-5 text-sm text-[#4B5563] leading-relaxed space-y-3">
        <p>
          Start with <a href="/division/facts" class="text-[#4F46E5] font-medium hover:underline">exact division facts</a> before introducing remainders. This builds confidence and makes division patterns easier to recognize.
        </p>
        <p>
          Use <a href="/division/divide-by/2" class="text-[#4F46E5] font-medium hover:underline">one-divisor practice</a> (like divide by 2, 3, or 4) to reinforce specific fact families. Focused repetition helps students retain facts faster.
        </p>
        <p>
          After fact fluency, move to <a href="/division/remainders" class="text-[#4F46E5] font-medium hover:underline">division with remainders</a>. Encourage students to explain what the remainder means in context, not just compute it.
        </p>
      </div>
    </section>

    <section class="mt-12" aria-labelledby="related-heading">
      <h2 id="related-heading" class="text-base font-semibold text-[#1E293B] mb-3">Related Practice</h2>
      <InternalLinks client:load links={relatedLinks} />
    </section>

    <section class="mt-12" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        {faqItems.map(({ q, a }) => (
          <div class="bg-white border border-[#E2E8F0] rounded-xl px-5 py-4">
            <h3 class="text-sm font-semibold text-[#1E293B] mb-1.5">{q}</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </section>
  </main>

  <footer class="border-t-2 border-[#E0E7FF] bg-[#EEF2FF] mt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#6366F1]">
        <a href="/" class="hover:text-[#3730A3] transition-colors">Home</a>
        <a href="/math-practice" class="hover:text-[#3730A3] transition-colors">Math Practice</a>
        <a href="/addition" class="hover:text-[#3730A3] transition-colors">Addition</a>
        <a href="/subtraction" class="hover:text-[#3730A3] transition-colors">Subtraction</a>
        <a href="/multiplication" class="hover:text-[#3730A3] transition-colors">Multiplication</a>
        <a href="/division" class="hover:text-[#3730A3] transition-colors">Division</a>
        <a href="/math-worksheets" class="hover:text-[#3730A3] transition-colors">Worksheets</a>
      </div>
      <p class="text-xs text-[#A5B4FC] mt-4">© {new Date().getFullYear()} Math Practice. Free arithmetic practice for students of all ages.</p>
    </div>
  </footer>
</BaseLayout>
