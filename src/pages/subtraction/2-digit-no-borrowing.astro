---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import SubtractionPracticeHub from '@/components/SubtractionPracticeHub';
import InternalLinks from '@/components/InternalLinks';

const SITE = 'https://mathpracticeonline.com';

const links = [
  { href: '/subtraction', label: 'All Subtraction Levels', description: 'Compare levels or start from the beginning' },
  { href: '/subtraction/1-digit', label: '1-Digit Subtraction', description: 'Review subtraction fact fluency first' },
  { href: '/subtraction/2-digit-with-borrowing', label: '2-Digit Subtraction with Borrowing', description: 'Progress to regrouping subtraction' },
  { href: '/addition/2-digit-no-carrying', label: '2-Digit Addition (No Carrying)', description: 'Practice the inverse two-digit skill' },
  { href: '/math-worksheets/subtraction-worksheets', label: 'Subtraction Worksheets', description: 'Worksheet-style practice with instant feedback' },
];

const faqItems = [
  {
    q: 'What grade is 2-digit subtraction without borrowing?',
    a: 'Two-digit subtraction without borrowing is typically a Grade 1–Grade 2 skill. Students practice column subtraction before borrowing is introduced, building confidence with place-value alignment first.'
  },
  {
    q: 'What does "no borrowing" mean in subtraction?',
    a: 'A problem has no borrowing when every digit in the top number (minuend) is greater than or equal to the corresponding digit in the bottom number (subtrahend). Each column can be subtracted directly without regrouping. For example, 57 − 23: ones column 7 ≥ 3, tens column 5 ≥ 2 — no borrowing needed.'
  },
  {
    q: "What's the best way to check a subtraction answer?",
    a: 'Add the answer (difference) to the number you subtracted (subtrahend). If you get back the original number (minuend), the answer is correct. For 57 − 23 = 34: check 34 + 23 = 57. ✓ This inverse-operation check works for any subtraction problem.'
  },
  {
    q: 'Why practice subtraction without borrowing before borrowing?',
    a: 'Starting with no-borrowing problems lets students focus on place-value alignment and column subtraction in isolation, before adding the extra step of borrowing. The same progressive approach works in addition — students practice without carrying before tackling carrying.'
  },
];
---

<PracticeLayout
  title="2-Digit Subtraction Practice (No Borrowing) | Math Practice Online"
  description="Practice 2-digit subtraction without borrowing online. Build place-value accuracy with subtraction problems that do not require regrouping. Instant feedback and streak tracking."
  canonical={`${SITE}/subtraction/2-digit-no-borrowing`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Subtraction', href: '/subtraction' }, { label: '2-Digit Subtraction (No Borrowing)' }]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": "2-Digit Subtraction Practice (No Borrowing)",
      "description": "Interactive online practice for two-digit subtraction without regrouping. Every problem is constructed so no borrowing is required, letting students focus on place-value alignment.",
      "url": `${SITE}/subtraction/2-digit-no-borrowing`,
      "educationalLevel": ["Grade 1", "Grade 2"],
      "teaches": "Two-digit subtraction without regrouping",
      "provider": { "@type": "Organization", "name": "Math Practice Online", "url": SITE }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
  </Fragment>

  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">2-Digit Subtraction Practice (No Borrowing)</h1>
  <p slot="intro">Work on two-digit subtraction without regrouping to strengthen place-value alignment and written subtraction steps before introducing borrowing.</p>
  <SubtractionPracticeHub slot="widget" active="2-digit-no-borrowing" client:load />
  <InternalLinks slot="links" links={links} />

  <div slot="how-it-works" class="mt-12 space-y-8">
    <!-- Grade context -->
    <div class="flex items-center gap-2">
      <span class="text-xs font-semibold text-[#6366F1] bg-[#EEF2FF] px-3 py-1 rounded-full uppercase tracking-wide">Best for: Grade 1 – Grade 2</span>
    </div>

    <!-- What you'll practice -->
    <section aria-labelledby="what-heading">
      <h2 id="what-heading" class="text-lg font-semibold text-[#1E293B] mb-3">What You'll Practice</h2>
      <ul class="space-y-2 text-sm text-[#4B5563] leading-relaxed">
        <li class="flex items-start gap-2"><span class="text-[#4F46E5] font-bold mt-0.5">✓</span> Two-digit subtraction where each column can be solved independently</li>
        <li class="flex items-start gap-2"><span class="text-[#4F46E5] font-bold mt-0.5">✓</span> Problems from 10–99, constructed so no borrowing is ever needed</li>
        <li class="flex items-start gap-2"><span class="text-[#4F46E5] font-bold mt-0.5">✓</span> Aligning place values and subtracting ones and tens separately</li>
        <li class="flex items-start gap-2"><span class="text-[#4F46E5] font-bold mt-0.5">✓</span> Instant feedback with streak and score tracking</li>
      </ul>
    </section>

    <!-- How to solve -->
    <section aria-labelledby="howto-heading">
      <h2 id="howto-heading" class="text-lg font-semibold text-[#1E293B] mb-3">How to Solve 2-Digit Subtraction</h2>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="bg-white border border-[#E2E8F0] rounded-xl p-4">
          <div class="text-[#4F46E5] font-bold text-sm mb-1">Step 1</div>
          <h3 class="text-sm font-semibold text-[#1E293B] mb-1">Align the Columns</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Write both numbers with ones digits in the same column and tens digits in the same column. Proper alignment prevents place-value errors.</p>
        </div>
        <div class="bg-white border border-[#E2E8F0] rounded-xl p-4">
          <div class="text-[#4F46E5] font-bold text-sm mb-1">Step 2</div>
          <h3 class="text-sm font-semibold text-[#1E293B] mb-1">Subtract the Ones</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Subtract the bottom ones digit from the top ones digit. Write the result below the ones column. Example: 57 − 23 → ones: 7 − 3 = 4.</p>
        </div>
        <div class="bg-white border border-[#E2E8F0] rounded-xl p-4">
          <div class="text-[#4F46E5] font-bold text-sm mb-1">Step 3</div>
          <h3 class="text-sm font-semibold text-[#1E293B] mb-1">Subtract the Tens</h3>
          <p class="text-sm text-[#6B7280] leading-relaxed">Subtract the bottom tens digit from the top tens digit. Write the result. Example: 57 − 23 → tens: 5 − 2 = 3. Answer: 34.</p>
        </div>
      </div>
      <div class="mt-4 bg-[#EEF2FF] rounded-xl px-5 py-4 text-sm text-[#4B5563]">
        <span class="font-semibold text-[#1E293B]">Example:</span> 57 − 23 → ones: 7 − 3 = 4 → tens: 5 − 2 = 3 → <span class="font-semibold text-[#4F46E5]">Answer: 34</span>
      </div>
    </section>

    <!-- FAQ -->
    <section aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        {faqItems.map(({ q, a }) => (
          <div class="bg-white border border-[#E2E8F0] rounded-xl px-5 py-4">
            <h3 class="text-sm font-semibold text-[#1E293B] mb-1.5">{q}</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</PracticeLayout>
