---
import HubLayout from '@/layouts/HubLayout.astro';
import InternalLinks from '@/components/InternalLinks';

const SITE = 'https://mathpracticeonline.com';

const difficulties = [
  {
    href: '/subtraction/1-digit',
    label: '1-Digit Subtraction',
    grade: 'Kindergarten – Grade 1',
    description: 'Practice single-digit subtraction facts (1–9). Build speed and accuracy with the foundation of all subtraction.',
    symbol: '9 − 4',
  },
  {
    href: '/subtraction/2-digit-no-borrowing',
    label: '2-Digit Subtraction (No Borrowing)',
    grade: 'Grade 1 – Grade 2',
    description: 'Two-digit subtraction without regrouping. Master place-value alignment and column subtraction before introducing borrowing.',
    symbol: '57 − 23',
  },
  {
    href: '/subtraction/2-digit-with-borrowing',
    label: '2-Digit Subtraction with Borrowing',
    grade: 'Grade 2 – Grade 3',
    description: 'Two-digit subtraction with regrouping. Practice borrowing from the tens column to build advanced multi-digit fluency.',
    symbol: '74 − 38',
  },
];

const relatedLinks = [
  { href: '/addition/1-digit', label: '1-Digit Addition', description: 'Practice opposite facts (like 9−4 and 5+4)' },
  { href: '/addition/2-digit-with-carrying', label: 'Addition with Carrying', description: 'The matching addition skill for borrowing practice' },
  { href: '/math-worksheets/subtraction-worksheets', label: 'Subtraction Worksheets', description: 'Print extra subtraction pages for home or class' },
  { href: '/2nd-grade-math-practice', label: '2nd Grade Math Practice Online', description: 'Mixed 2nd-grade addition and subtraction practice' },
];

const faqItems = [
  {
    q: 'What grade level is 1-digit subtraction?',
    a: '1-digit subtraction is a core Kindergarten and Grade 1 skill. Students work toward fluency with all single-digit subtraction facts before moving on to two-digit subtraction.'
  },
  {
    q: 'What is borrowing in subtraction?',
    a: 'Borrowing (also called regrouping) occurs when the ones digit of the top number is smaller than the ones digit of the bottom number. You borrow 1 ten from the tens column — reducing the tens digit by 1 — and add 10 to the ones digit so that subtraction is possible. For example, 72 − 38: the ones column has 2 < 8, so borrow 1 ten → 12 − 8 = 4 ones; tens: 6 − 3 = 3 → answer 34.'
  },
  {
    q: 'What is the difference between subtraction with and without borrowing?',
    a: 'In subtraction without borrowing, every digit in the top number is greater than or equal to the corresponding digit in the bottom number, so each column can be subtracted directly (e.g., 57 − 23 = 34). In subtraction with borrowing, the ones digit of the top number is smaller, requiring a ten to be exchanged for 10 ones before subtracting (e.g., 72 − 38 requires borrowing).'
  },
  {
    q: 'How do I teach borrowing to a child?',
    a: 'Start with 1-digit subtraction to build fact fluency. Then introduce 2-digit subtraction without borrowing so students understand column alignment. Once that is solid, introduce borrowing: when the top ones digit is smaller than the bottom ones digit, cross out the tens digit, write it minus 1, and add 10 to the ones digit. Use base-ten blocks alongside written practice to make the concept concrete before it becomes abstract.'
  },
  {
    q: 'How does this subtraction practice work?',
    a: 'Practice runs continuously with instant right/wrong feedback after every answer. Your streak and best scores are saved automatically in your browser.'
  },
];
---

<HubLayout
  title="Subtraction Practice — Free Online Subtraction Drills | Math Practice Online"
  description="Free online subtraction practice for grades K–3. Choose 1-digit subtraction, 2-digit subtraction without borrowing, or 2-digit subtraction with borrowing. Instant feedback and streak tracking."
  canonical={`${SITE}/subtraction`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mathpracticeonline.com/" },
        { "@type": "ListItem", "position": 2, "name": "Subtraction Practice" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": "Subtraction Practice",
      "description": "Free online subtraction practice for grades K–3 covering 1-digit, 2-digit without borrowing, and 2-digit with borrowing. Instant feedback and progress tracking.",
      "url": "https://mathpracticeonline.com/subtraction",
      "educationalLevel": ["Kindergarten", "Grade 1", "Grade 2", "Grade 3"],
      "teaches": "Subtraction",
      "provider": {
        "@type": "Organization",
        "name": "Math Practice Online",
        "url": "https://mathpracticeonline.com"
      }
    })} />
  </Fragment>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-5 text-sm text-[#A5B4FC] flex items-center flex-wrap gap-1">
      <a href="/" class="hover:text-[#4F46E5] transition-colors">Home</a>
      <span aria-hidden="true" class="text-[#C7D2FE]/40">›</span>
      <span class="text-[#6B7280]">Subtraction Practice</span>
    </nav>

    <!-- H1 + intro -->
    <h1 class="text-3xl font-bold text-[#1E293B]">Subtraction Practice</h1>
    <p class="mt-3 mb-8 text-[#6B7280] text-base leading-relaxed max-w-xl">
      Free online subtraction practice for grades K–3. Choose a difficulty level below — each opens an interactive drill with instant feedback and streak tracking.
    </p>

    <!-- Difficulty cards -->
    <section aria-labelledby="levels-heading">
      <h2 id="levels-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Choose a Difficulty Level</h2>
      <div class="flex flex-col gap-4">
        {difficulties.map((d) => (
          <a
            href={d.href}
            class="flex items-start gap-4 bg-white border border-[#E2E8F0] rounded-2xl p-5 hover:border-[#4F46E5] hover:shadow-md transition-all group"
          >
            <div class="w-16 h-14 rounded-xl bg-[#EEF2FF] flex items-center justify-center font-mono text-sm font-bold text-[#4F46E5] shrink-0 leading-tight text-center">
              {d.symbol}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline gap-2 flex-wrap">
                <span class="font-semibold text-[#1E293B] group-hover:text-[#4F46E5] transition-colors">{d.label}</span>
                <span class="text-xs font-medium text-[#6366F1] bg-[#EEF2FF] px-2 py-0.5 rounded-full">{d.grade}</span>
              </div>
              <p class="text-sm text-[#6B7280] mt-1 leading-relaxed">{d.description}</p>
            </div>
            <span class="text-[#A5B4FC] group-hover:text-[#4F46E5] transition-colors text-lg leading-none mt-1" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Grade progression -->
    <section class="mt-12" aria-labelledby="progression-heading">
      <h2 id="progression-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Grade-by-Grade Progression</h2>
      <div class="bg-white border border-[#E2E8F0] rounded-2xl overflow-hidden">
        <div class="divide-y divide-[#E2E8F0]">
          <div class="flex items-start gap-4 px-5 py-4">
            <span class="w-20 text-xs font-semibold text-[#6366F1] uppercase tracking-wide pt-0.5 shrink-0">K – Grade 1</span>
            <div>
              <p class="text-sm font-medium text-[#1E293B]">1-Digit Subtraction</p>
              <p class="text-sm text-[#6B7280] mt-0.5">Learn to subtract numbers 1–9. Build fluency with all single-digit subtraction facts. This core foundation makes every later skill easier — and connects directly to addition fact families.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-5 py-4">
            <span class="w-20 text-xs font-semibold text-[#6366F1] uppercase tracking-wide pt-0.5 shrink-0">Grade 1 – 2</span>
            <div>
              <p class="text-sm font-medium text-[#1E293B]">2-Digit Subtraction (No Borrowing)</p>
              <p class="text-sm text-[#6B7280] mt-0.5">Extend single-digit fluency to two-digit numbers. Learn to align columns by place value and subtract tens and ones independently — without regrouping.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 px-5 py-4">
            <span class="w-20 text-xs font-semibold text-[#6366F1] uppercase tracking-wide pt-0.5 shrink-0">Grade 2 – 3</span>
            <div>
              <p class="text-sm font-medium text-[#1E293B]">2-Digit Subtraction with Borrowing</p>
              <p class="text-sm text-[#6B7280] mt-0.5">Master regrouping. When the ones digit is too small to subtract from, borrow 1 ten from the tens column. This skill extends directly to 3-digit and larger subtraction.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tips section -->
    <section class="mt-12" aria-labelledby="tips-heading">
      <h2 id="tips-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Tips for Parents and Teachers</h2>
      <div class="bg-[#EEF2FF] rounded-2xl px-5 py-5 text-sm text-[#4B5563] leading-relaxed space-y-3">
        <p>
          Start with <a href="/subtraction/1-digit" class="text-[#4F46E5] font-medium hover:underline">1-digit subtraction</a> and practice daily until students can answer any single-digit fact quickly. Fluency here (typically by end of Grade 1) is the bedrock for everything that follows — and works best when paired with addition fact families.
        </p>
        <p>
          When moving to 2-digit subtraction, begin with <a href="/subtraction/2-digit-no-borrowing" class="text-[#4F46E5] font-medium hover:underline">no-borrowing problems</a> first. This isolates place-value alignment from the complexity of regrouping, giving students a chance to practice the column-subtraction process cleanly.
        </p>
        <p>
          Introduce <a href="/subtraction/2-digit-with-borrowing" class="text-[#4F46E5] font-medium hover:underline">borrowing</a> only after no-borrowing problems feel easy. Use base-ten blocks alongside screen practice to make the concept concrete before it becomes abstract.
        </p>
      </div>
    </section>

    <!-- Related links -->
    <section class="mt-12" aria-labelledby="related-heading">
      <h2 id="related-heading" class="text-base font-semibold text-[#1E293B] mb-3">Related Practice</h2>
      <InternalLinks client:load links={relatedLinks} />
    </section>

    <!-- FAQ -->
    <section class="mt-12" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-lg font-semibold text-[#1E293B] mb-4">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        {faqItems.map(({ q, a }) => (
          <div class="bg-white border border-[#E2E8F0] rounded-xl px-5 py-4">
            <h3 class="text-sm font-semibold text-[#1E293B] mb-1.5">{q}</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </section>
  </main>

</HubLayout>
