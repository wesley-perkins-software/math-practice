---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/global.css';

const SITE = 'https://www.mathpractice.com';

const operations = [
  {
    href: '/addition-practice',
    label: 'Addition Practice',
    symbol: '+',
    color: '#2563EB',
    bg: '#DBEAFE',
    desc: 'Addition facts, 1-digit and 2-digit addition, plus addition with carrying.',
  },
  {
    href: '/subtraction-practice',
    label: 'Subtraction Practice',
    symbol: '−',
    color: '#7C3AED',
    bg: '#EDE9FE',
    desc: 'Subtraction facts, 1-digit and 2-digit subtraction, and subtraction with borrowing.',
  },
  {
    href: '/multiplication-practice',
    label: 'Multiplication Practice',
    symbol: '×',
    color: '#059669',
    bg: '#D1FAE5',
    desc: 'Multiplication facts, times tables, and mixed multiplication fluency drills.',
  },
  {
    href: '/division-practice',
    label: 'Division Practice',
    symbol: '÷',
    color: '#D97706',
    bg: '#FEF3C7',
    desc: 'Division facts and whole-number division practice with clear, focused problems.',
  },
];

const popularPages = [
  {
    href: '/addition-practice/1-digit',
    label: '1-Digit Addition Practice',
    detail: 'Quick fact fluency for early learners',
  },
  {
    href: '/addition-practice/2-digit',
    label: '2-Digit Addition Practice',
    detail: 'Build accuracy with larger sums',
  },
  {
    href: '/addition-practice/2-digit-carrying',
    label: 'Addition with Carrying',
    detail: 'Step up to regrouping confidence',
  },
  {
    href: '/subtraction-practice/2-digit-borrowing',
    label: 'Subtraction with Borrowing',
    detail: 'Practice regrouping and subtraction fluency',
  },
  {
    href: '/multiplication-practice/facts',
    label: 'Multiplication Facts',
    detail: 'Times table speed and recall',
  },
  {
    href: '/division-practice/facts',
    label: 'Division Facts',
    detail: 'Whole-number division fact practice',
  },
  {
    href: '/arithmetic-speed-drill',
    label: 'Timed Math Drills',
    detail: 'Beat the clock with mixed operations',
  },
  {
    href: '/mental-math-practice',
    label: 'Mental Math Practice',
    detail: 'Fast, focused head-math workouts',
  },
];
---

<BaseLayout
  title="Free Math Practice & Arithmetic Drills for Addition, Subtraction, Multiplication, and Division"
  description="Free online math practice for addition, subtraction, multiplication, and division. Fast arithmetic drills that build speed and confidence for students, parents, and teachers."
  canonical={`${SITE}/`}
>
  <header class="border-b border-[#E2E8F0] bg-white/90 backdrop-blur-sm">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
      <a href="/" class="text-lg font-bold tracking-tight text-[#1E293B]">Math Practice</a>
      <nav class="hidden items-center gap-5 text-sm font-medium text-[#64748B] md:flex">
        <a href="/addition-practice" class="transition-colors hover:text-[#1E293B]">Addition</a>
        <a href="/subtraction-practice" class="transition-colors hover:text-[#1E293B]">Subtraction</a>
        <a href="/multiplication-practice" class="transition-colors hover:text-[#1E293B]">Multiplication</a>
        <a href="/division-practice" class="transition-colors hover:text-[#1E293B]">Division</a>
      </nav>
    </div>
  </header>

  <main class="pb-14">
    <section class="mx-auto max-w-6xl px-4 pb-12 pt-10 sm:px-6 sm:pb-14 sm:pt-14">
      <div class="rounded-3xl border border-[#E2E8F0] bg-gradient-to-b from-white to-[#F8FAFF] px-5 py-10 shadow-sm sm:px-8 sm:py-12">
        <p class="text-sm font-semibold uppercase tracking-wide text-[#3B82F6]">Free online math practice</p>
        <h1 class="mt-3 max-w-3xl text-3xl font-bold leading-tight text-[#1E293B] sm:text-5xl">
          Math practice that builds speed and confidence.
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-[#475569] sm:text-lg">
          Get fast, focused arithmetic practice for addition, subtraction, multiplication, and division. Great for students, parents, and teachers who want daily progress without setup.
        </p>

        <div class="mt-6 grid gap-2 text-sm text-[#334155] sm:grid-cols-3 sm:gap-3">
          <div class="rounded-xl border border-[#DBEAFE] bg-[#EFF6FF] px-3 py-2 font-medium">No login required</div>
          <div class="rounded-xl border border-[#DBEAFE] bg-[#EFF6FF] px-3 py-2 font-medium">Start in seconds</div>
          <div class="rounded-xl border border-[#DBEAFE] bg-[#EFF6FF] px-3 py-2 font-medium">Works on phones, tablets, and desktops</div>
        </div>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href="/math-practice"
            class="inline-flex min-h-12 items-center justify-center rounded-xl bg-[#3B82F6] px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-[#2563EB]"
          >
            Start Math Practice
          </a>
          <a
            href="/arithmetic-speed-drill"
            class="inline-flex min-h-12 items-center justify-center rounded-xl border border-[#CBD5E1] bg-white px-6 py-3 text-base font-semibold text-[#1E293B] transition-colors hover:border-[#3B82F6] hover:text-[#2563EB]"
          >
            Try Timed Speed Drills
          </a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 py-4 sm:px-6 sm:py-6">
      <div class="mb-6 flex items-end justify-between gap-3">
        <div>
          <h2 class="text-2xl font-bold text-[#1E293B]">Practice by core math skill</h2>
          <p class="mt-1 text-sm text-[#64748B]">Choose a topic and jump into focused arithmetic drills.</p>
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {operations.map((op) => (
          <a
            href={op.href}
            class="group rounded-2xl border border-[#E2E8F0] bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:border-[#BFDBFE] hover:shadow-md"
          >
            <div
              class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl text-2xl font-bold"
              style={`background:${op.bg};color:${op.color}`}
            >
              {op.symbol}
            </div>
            <h3 class="text-base font-semibold text-[#1E293B] transition-colors group-hover:text-[#2563EB]">{op.label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[#64748B]">{op.desc}</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-[#2563EB]">Explore practice →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="mx-auto mt-10 max-w-6xl px-4 sm:px-6">
      <div class="rounded-2xl border border-[#E2E8F0] bg-white p-5 sm:p-7">
        <h2 class="text-2xl font-bold text-[#1E293B]">Popular practice pages</h2>
        <p class="mt-2 text-sm text-[#64748B]">Curated drills for math facts, carrying, borrowing, and timed arithmetic practice.</p>
        <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {popularPages.map((page) => (
            <a
              href={page.href}
              class="rounded-xl border border-[#E2E8F0] bg-[#FCFDFE] px-4 py-4 transition-colors hover:border-[#BFDBFE] hover:bg-white"
            >
              <div class="text-sm font-semibold text-[#1E293B]">{page.label}</div>
              <div class="mt-1 text-xs text-[#64748B]">{page.detail}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="mx-auto mt-10 max-w-6xl px-4 sm:px-6">
      <div class="rounded-2xl border border-[#E2E8F0] bg-[#F8FAFC] px-5 py-6 sm:px-7 sm:py-8">
        <h2 class="text-xl font-bold text-[#1E293B]">Built for students, parents, and teachers</h2>
        <p class="mt-2 max-w-3xl text-sm leading-relaxed text-[#475569] sm:text-base">
          Use Math Practice for daily fluency, homework support, and quick classroom warm-ups. Every drill is designed to build arithmetic speed and confidence with low-friction, repeatable practice.
        </p>
      </div>
    </section>
  </main>

  <footer class="mt-8 border-t border-[#E2E8F0]">
    <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#64748B]">
        <a href="/math-practice" class="hover:text-[#1E293B]">Math Practice</a>
        <a href="/math-drills" class="hover:text-[#1E293B]">Math Drills</a>
        <a href="/addition-practice" class="hover:text-[#1E293B]">Addition</a>
        <a href="/subtraction-practice" class="hover:text-[#1E293B]">Subtraction</a>
        <a href="/multiplication-practice" class="hover:text-[#1E293B]">Multiplication</a>
        <a href="/division-practice" class="hover:text-[#1E293B]">Division</a>
      </div>
      <p class="mt-4 text-xs text-[#94A3B8]">© {new Date().getFullYear()} Math Practice. Free arithmetic practice for addition, subtraction, multiplication, and division.</p>
    </div>
  </footer>
</BaseLayout>
