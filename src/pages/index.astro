---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/global.css';

const SITE = 'https://www.mathpractice.com';

const operations = [
  {
    href: '/addition',
    label: 'Addition Practice',
    symbol: '+',
    color: '#2563EB',
    bg: '#EFF6FF',
    ring: 'rgba(37,99,235,0.35)',
    practices: ['1-Digit Addition', '2-Digit Addition', 'Addition with Carrying'],
  },
  {
    href: '/subtraction',
    label: 'Subtraction Practice',
    symbol: '−',
    color: '#7C3AED',
    bg: '#F5F3FF',
    ring: 'rgba(124,58,237,0.35)',
    practices: ['1-Digit Subtraction', '2-Digit Subtraction', 'Subtraction with Borrowing'],
  },
  {
    href: '/multiplication',
    label: 'Multiplication Practice',
    symbol: '×',
    color: '#059669',
    bg: '#ECFDF5',
    ring: 'rgba(5,150,105,0.35)',
    practices: ['Multiplication Facts', 'Times Tables 1–12'],
  },
  {
    href: '/division',
    label: 'Division Practice',
    symbol: '÷',
    color: '#D97706',
    bg: '#FFFBEB',
    ring: 'rgba(217,119,6,0.35)',
    practices: ['Division Facts', 'Division without Remainder', 'Division with Remainder'],
  },
];
---

<BaseLayout
  title="Math Practice — Free Arithmetic Drills for Students"
  description="Free math practice for addition, subtraction, multiplication, and division. Instant feedback and progress tracking for students in grades K–5."
  canonical={`${SITE}/`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "EducationalApplication",
      "name": "Math Practice",
      "url": "https://www.mathpractice.com/",
      "description": "Free online arithmetic practice for grades K–5. Practice addition, subtraction, multiplication, and division with instant feedback and progress tracking.",
      "applicationCategory": "EducationalApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "educationalLevel": ["Kindergarten", "Grade 1", "Grade 2", "Grade 3", "Grade 4", "Grade 5"],
      "teaches": ["Addition", "Subtraction", "Multiplication", "Division", "Arithmetic"]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Is Math Practice free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, completely free. No account, no subscription, and no ads. Every practice mode on the site is available to anyone."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need to create an account or log in?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Practice starts the moment you arrive. There's no signup, no login, and no personal data collected."
          }
        },
        {
          "@type": "Question",
          "name": "What grades is this site designed for?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The content covers grades K–5 (roughly ages 5–11), from basic 1-digit addition through 2-digit arithmetic, times tables, and division with remainders. The site is useful for any student who wants to build arithmetic fluency."
          }
        },
        {
          "@type": "Question",
          "name": "How does progress tracking work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Your scores, streaks, and session history are stored in your browser's local storage. Nothing is sent to a server — your data stays on your device."
          }
        },
        {
          "@type": "Question",
          "name": "What types of math can I practice?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Addition (1-digit and 2-digit, with and without carrying), subtraction (1-digit and 2-digit, with and without borrowing), multiplication (mixed facts and times tables 1–12), and division (facts and division with remainders)."
          }
        },
        {
          "@type": "Question",
          "name": "Are there timed practice modes?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Math Drills (2 minutes), Arithmetic Speed Drill (60 seconds), and Mental Math Practice (60 seconds) are all timed. Each drill has a fixed duration matched to its purpose."
          }
        },
        {
          "@type": "Question",
          "name": "Does this work on phones and tablets?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The site is fully responsive and includes a touch-optimized number pad so it works well without a keyboard — on any phone, tablet, or desktop."
          }
        },
        {
          "@type": "Question",
          "name": "Can teachers use this site with students?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The site requires no accounts, no downloads, and works in any modern browser on any device — making it easy to use in a classroom, computer lab, or at home for homework."
          }
        }
      ]
    })} />
  </Fragment>
  <!-- Site Header -->
  <header class="bg-[#1E1B4B] sticky top-0 z-20 shadow-[0_1px_0_0_#312E81]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3.5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <span class="w-7 h-7 rounded-lg bg-[#4F46E5] flex items-center justify-center text-white font-black text-sm leading-none select-none group-hover:bg-[#6366F1] transition-colors">÷</span>
        <span class="text-base font-bold text-white tracking-tight">Math Practice</span>
      </a>
      <nav class="hidden sm:flex items-center gap-1">
        <a href="/addition" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Addition</a>
        <a href="/subtraction" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Subtraction</a>
        <a href="/multiplication" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Multiplication</a>
        <a href="/division" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Division</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <!-- Dark gradient background -->
      <div class="absolute inset-x-0 top-0 h-[560px] bg-gradient-to-b from-[#1E1B4B] via-[#312E81] to-[#F5F3FF]"></div>

      <!-- Ghost math symbol watermarks -->
      <div class="absolute inset-x-0 top-0 h-[560px] overflow-hidden pointer-events-none select-none" aria-hidden="true">
        <span class="absolute top-6 left-[6%] text-[130px] font-black text-white/[0.04] leading-none">+</span>
        <span class="absolute top-4 right-[5%] text-[150px] font-black text-white/[0.04] leading-none">÷</span>
        <span class="absolute top-24 left-[18%] text-[100px] font-black text-white/[0.04] leading-none">×</span>
        <span class="absolute top-16 right-[20%] text-[110px] font-black text-white/[0.04] leading-none">−</span>
      </div>

      <!-- Hero content -->
      <div class="relative max-w-2xl mx-auto px-4 sm:px-6 pt-16 pb-20 text-center">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-1.5 bg-white/10 border border-white/20 rounded-full px-4 py-1 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#34D399]"></span>
          <span class="text-xs font-semibold text-white/90 tracking-wide uppercase">Free · No login required</span>
        </div>

        <h1 class="text-5xl sm:text-6xl font-extrabold text-white leading-[1.05] tracking-tight">
          Build math skills,<br />
          <span class="text-[#A5B4FC]">one problem at a time</span>
        </h1>
        <p class="mt-5 text-lg text-white/80 max-w-lg mx-auto leading-relaxed">
          Free arithmetic practice for grades K–5. Addition, subtraction,
          multiplication, and division — with instant feedback and no pressure.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/addition"
            class="px-6 py-3 rounded-xl bg-[#4F46E5] hover:bg-[#6366F1] text-white font-semibold text-base transition-all shadow-[0_4px_14px_rgba(79,70,229,0.5)] hover:shadow-[0_6px_20px_rgba(99,102,241,0.5)] hover:-translate-y-0.5"
          >
            Start Practicing
          </a>
        </div>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-white/55">
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#34D399]/80 shrink-0"></span>Works on any device
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#34D399]/80 shrink-0"></span>Instant feedback
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#34D399]/80 shrink-0"></span>Free forever
          </span>
        </div>
      </div>
    </section>

    <!-- Operation Cards -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-[#1E1B4B]">Choose an operation</h2>
        <p class="text-[#6B7280] mt-1 text-base">Select any topic to start practicing right away.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {operations.map((op) => (
          <a
            href={op.href}
            class="flex flex-col bg-white rounded-2xl overflow-hidden ring-1 ring-[#E0E7FF] hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-all duration-200 group"
            style={`--op-ring: ${op.ring}`}
          >
            <!-- Icon block -->
            <div class="px-6 py-7 flex flex-col items-center gap-4" style={`background:${op.bg}`}>
              <div
                class="w-16 h-16 rounded-2xl flex items-center justify-center shadow-md"
                style={`background:${op.color}`}
              >
                <span class="text-3xl font-black text-white leading-none select-none">{op.symbol}</span>
              </div>
              <div class="text-base font-bold text-[#1E1B4B] text-center leading-tight">
                {op.label}
              </div>
            </div>

            <!-- Practice list -->
            <div class="px-5 py-4 flex flex-col gap-2 flex-1 border-t border-[#E0E7FF]">
              {op.practices.map((p) => (
                <div class="flex items-center gap-2.5 text-sm text-[#4B5563]">
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${op.color}`}></span>
                  {p}
                </div>
              ))}
            </div>

            <!-- CTA row -->
            <div class="px-5 pb-5 pt-2">
              <span
                class="text-sm font-bold transition-all inline-flex items-center gap-1 group-hover:gap-2"
                style={`color:${op.color}`}
              >
                Practice <span class="transition-all">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- How It Works -->
    <section class="bg-white border-t border-[#E0E7FF]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-[#1E1B4B]">How It Works</h2>
          <p class="text-[#6B7280] mt-2 text-base max-w-xl mx-auto">
            From kindergarten addition to 5th-grade division — practice in three simple steps.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="text-5xl font-extrabold text-[#4F46E5] mb-4 leading-none">1</div>
            <h3 class="text-lg font-bold text-[#1E1B4B] mb-2">Choose Your Topic</h3>
            <p class="text-[#6B7280] text-sm leading-relaxed">
              Pick any operation — addition, subtraction, multiplication, or division — and select your level.
              Every topic is free with no login required.
            </p>
          </div>
          <div class="text-center">
            <div class="text-5xl font-extrabold text-[#4F46E5] mb-4 leading-none">2</div>
            <h3 class="text-lg font-bold text-[#1E1B4B] mb-2">Solve Problems</h3>
            <p class="text-[#6B7280] text-sm leading-relaxed">
              Answer arithmetic problems at your own pace. Each answer is checked instantly so you always
              know if you're on track — no waiting for a teacher to grade your work.
            </p>
          </div>
          <div class="text-center">
            <div class="text-5xl font-extrabold text-[#4F46E5] mb-4 leading-none">3</div>
            <h3 class="text-lg font-bold text-[#1E1B4B] mb-2">Track Your Progress</h3>
            <p class="text-[#6B7280] text-sm leading-relaxed">
              Your scores and streaks are saved automatically in your browser. Return any time to see
              how your speed and accuracy improve over time.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Practice by Grade Level -->
    <section>
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-[#1E1B4B]">Practice by Grade Level</h2>
          <p class="text-[#6B7280] mt-2 text-base max-w-xl mx-auto">
            Find the right level for any K–5 student. Each section links directly to practice problems
            matched to that grade band.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <!-- K–1 -->
          <div class="bg-white rounded-2xl p-6 ring-1 ring-[#E0E7FF]">
            <div class="inline-flex items-center bg-[#EFF6FF] text-[#2563EB] text-xs font-bold px-3 py-1 rounded-full mb-4">
              Grades K–1
            </div>
            <h3 class="text-base font-bold text-[#1E1B4B] mb-2 leading-snug">
              Kindergarten &amp; 1st Grade — Addition &amp; Subtraction Basics
            </h3>
            <p class="text-sm text-[#6B7280] leading-relaxed mb-4">
              Start with single-digit addition and subtraction — facts within 10 and 20. These are
              the building blocks of early arithmetic and the foundation for everything that follows.
            </p>
            <div class="flex flex-col gap-2">
              <a href="/addition/1-digit" class="text-sm font-semibold text-[#2563EB] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> 1-Digit Addition
              </a>
              <a href="/subtraction/1-digit" class="text-sm font-semibold text-[#2563EB] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> 1-Digit Subtraction
              </a>
            </div>
          </div>
          <!-- 2–3 -->
          <div class="bg-white rounded-2xl p-6 ring-1 ring-[#E0E7FF]">
            <div class="inline-flex items-center bg-[#F5F3FF] text-[#7C3AED] text-xs font-bold px-3 py-1 rounded-full mb-4">
              Grades 2–3
            </div>
            <h3 class="text-base font-bold text-[#1E1B4B] mb-2 leading-snug">
              2nd &amp; 3rd Grade — Regrouping, Multiplication &amp; Division Facts
            </h3>
            <p class="text-sm text-[#6B7280] leading-relaxed mb-4">
              Practice 2-digit addition and subtraction with carrying and borrowing. In 3rd grade,
              multiplication facts become a central skill — and division facts begin too. This is
              a critical year for arithmetic fluency.
            </p>
            <div class="flex flex-col gap-2">
              <a href="/addition/2-digit-no-carrying" class="text-sm font-semibold text-[#7C3AED] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> 2-Digit Addition (No Carrying)
              </a>
              <a href="/addition/2-digit-with-carrying" class="text-sm font-semibold text-[#7C3AED] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> 2-Digit Addition with Carrying
              </a>
              <a href="/subtraction/2-digit-no-borrowing" class="text-sm font-semibold text-[#7C3AED] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> 2-Digit Subtraction
              </a>
              <a href="/subtraction/2-digit-with-borrowing" class="text-sm font-semibold text-[#7C3AED] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> Subtraction with Borrowing
              </a>
              <a href="/multiplication/facts" class="text-sm font-semibold text-[#7C3AED] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> Multiplication Facts
              </a>
              <a href="/division/facts" class="text-sm font-semibold text-[#7C3AED] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> Division Facts
              </a>
            </div>
          </div>
          <!-- 4–5 -->
          <div class="bg-white rounded-2xl p-6 ring-1 ring-[#E0E7FF]">
            <div class="inline-flex items-center bg-[#ECFDF5] text-[#059669] text-xs font-bold px-3 py-1 rounded-full mb-4">
              Grades 4–5
            </div>
            <h3 class="text-base font-bold text-[#1E1B4B] mb-2 leading-snug">
              4th &amp; 5th Grade — Fluency, Speed &amp; Division with Remainders
            </h3>
            <p class="text-sm text-[#6B7280] leading-relaxed mb-4">
              Build fluency and speed with multiplication and division. Practice division with
              remainders, reinforce times tables, and develop confidence with timed drills —
              the skills that carry students into middle school math.
            </p>
            <div class="flex flex-col gap-2">
              <a href="/division/facts" class="text-sm font-semibold text-[#059669] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> Division Facts
              </a>
              <a href="/division/remainders" class="text-sm font-semibold text-[#059669] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> Division with Remainders
              </a>
              <a href="/multiplication/times-tables/1" class="text-sm font-semibold text-[#059669] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> Times Tables 1–12
              </a>
              <a href="/multiplication/facts" class="text-sm font-semibold text-[#059669] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> Mixed Multiplication Facts
              </a>
              <a href="/math-drills" class="text-sm font-semibold text-[#059669] hover:underline flex items-center gap-1">
                <span aria-hidden="true">→</span> Timed Math Drills
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Timed Drills & Speed Practice -->
    <section class="bg-white border-t border-[#E0E7FF]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-[#1E1B4B]">Timed Drills &amp; Speed Practice</h2>
          <p class="text-[#6B7280] mt-2 text-base max-w-2xl mx-auto">
            Build arithmetic speed alongside accuracy. Timed drills are especially effective for
            test preparation and for developing automatic recall of math facts.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="bg-[#F5F3FF] rounded-2xl p-6 ring-1 ring-[#E0E7FF] flex flex-col">
            <div class="flex items-start justify-between mb-3">
              <span class="text-2xl" aria-hidden="true">⏱</span>
              <span class="bg-[#EEF2FF] text-[#4F46E5] text-xs font-bold px-2.5 py-0.5 rounded-full">All 4 Operations</span>
            </div>
            <h3 class="text-base font-bold text-[#1E1B4B] mb-2">Math Drills</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed flex-1">
              Two-minute mixed drill across all four operations. Deliberate pacing — wrong answers
              show the correct solution before moving on. Perfect for building fluency and learning
              from mistakes.
            </p>
            <a href="/timed-drills" class="mt-4 text-sm font-bold text-[#4F46E5] hover:text-[#3730A3] inline-flex items-center gap-1 transition-colors">
              View Timed Drills <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="bg-[#F5F3FF] rounded-2xl p-6 ring-1 ring-[#E0E7FF] flex flex-col">
            <div class="flex items-start justify-between mb-3">
              <span class="text-2xl" aria-hidden="true">⚡</span>
              <span class="bg-[#EEF2FF] text-[#4F46E5] text-xs font-bold px-2.5 py-0.5 rounded-full">Beat the Clock</span>
            </div>
            <h3 class="text-base font-bold text-[#1E1B4B] mb-2">Arithmetic Speed Drill</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed flex-1">
              60 seconds, maximum throughput. Answers clear almost instantly so nothing slows
              you down. The fastest-paced drill on the site — your score is how many you answer
              correctly. Try to beat your personal best.
            </p>
            <a href="/timed-drills" class="mt-4 text-sm font-bold text-[#4F46E5] hover:text-[#3730A3] inline-flex items-center gap-1 transition-colors">
              View Timed Drills <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="bg-[#F5F3FF] rounded-2xl p-6 ring-1 ring-[#E0E7FF] flex flex-col">
            <div class="flex items-start justify-between mb-3">
              <span class="text-2xl" aria-hidden="true">🧠</span>
              <span class="bg-[#EEF2FF] text-[#4F46E5] text-xs font-bold px-2.5 py-0.5 rounded-full">Two-Digit Mental Math</span>
            </div>
            <h3 class="text-base font-bold text-[#1E1B4B] mb-2">Mental Math Practice</h3>
            <p class="text-sm text-[#6B7280] leading-relaxed flex-1">
              60 seconds of two-digit addition and subtraction — no pencil and paper. Practice
              the mental arithmetic you use in everyday life: calculating change, estimating
              totals, splitting costs. Ideal for grades 3 and up.
            </p>
            <a href="/timed-drills" class="mt-4 text-sm font-bold text-[#4F46E5] hover:text-[#3730A3] inline-flex items-center gap-1 transition-colors">
              View Timed Drills <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
        <div class="mt-8 text-center flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/timed-drills" class="text-sm text-[#6B7280] hover:text-[#4F46E5] transition-colors">
            <span class="font-semibold text-[#4F46E5]">Compare all timed drills</span> — find the right format for you <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Complete Math Practice Index -->
    <section>
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-[#1E1B4B]">Complete Math Practice Index</h2>
          <p class="text-[#6B7280] mt-2 text-base max-w-xl mx-auto">
            Every practice page on the site, organized by topic. Navigate directly to any
            skill level or drill type.
          </p>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- Addition -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="w-7 h-7 rounded-lg bg-[#2563EB] flex items-center justify-center text-white font-black text-sm leading-none" aria-hidden="true">+</span>
              <span class="text-sm font-bold text-[#1E1B4B]">Addition</span>
            </div>
