---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/global.css';

const SITE = 'https://www.mathpractice.com';

const operations = [
  {
    href: '/addition-practice/1-digit',
    label: 'Addition Practice',
    symbol: '+',
    color: '#3B82F6',
    bg: '#EFF6FF',
    practices: ['1-Digit Addition', '2-Digit Addition', 'Addition with Carrying'],
  },
  {
    href: '/subtraction-practice',
    label: 'Subtraction Practice',
    symbol: '−',
    color: '#8B5CF6',
    bg: '#F5F3FF',
    practices: ['1-Digit Subtraction', '2-Digit Subtraction', 'Subtraction with Borrowing'],
  },
  {
    href: '/multiplication-practice',
    label: 'Multiplication Practice',
    symbol: '×',
    color: '#10B981',
    bg: '#ECFDF5',
    practices: ['Multiplication Facts', 'Times Tables 1–12'],
  },
  {
    href: '/division-practice',
    label: 'Division Practice',
    symbol: '÷',
    color: '#F59E0B',
    bg: '#FFFBEB',
    practices: ['Division Facts', 'Division without Remainder', 'Division with Remainder'],
  },
];
---

<BaseLayout
  title="Math Practice — Free Arithmetic Drills for Students"
  description="Free math practice for addition, subtraction, multiplication, and division. Instant feedback and progress tracking for students in grades K–5."
  canonical={`${SITE}/`}
>
  <header class="border-b border-[#E2E8F0] bg-white sticky top-0 z-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-[#1E293B]">Math Practice</a>
      <nav class="hidden sm:flex items-center gap-5 text-sm font-medium text-[#64748B]">
        <a href="/addition-practice/1-digit" class="hover:text-[#1E293B] transition-colors">Addition</a>
        <a href="/subtraction-practice" class="hover:text-[#1E293B] transition-colors">Subtraction</a>
        <a href="/multiplication-practice" class="hover:text-[#1E293B] transition-colors">Multiplication</a>
        <a href="/division-practice" class="hover:text-[#1E293B] transition-colors">Division</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="max-w-2xl mx-auto px-4 sm:px-6 pt-14 pb-10 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-[#1E293B] leading-tight tracking-tight">
        Build math skills,<br />one problem at a time
      </h1>
      <p class="mt-4 text-lg text-[#64748B] max-w-lg mx-auto leading-relaxed">
        Free arithmetic practice for students in grades K–5.
        Addition, subtraction, multiplication, and division —
        with instant feedback and no pressure.
      </p>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-[#64748B]">
        <span class="flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-[#22C55E] shrink-0"></span>No login required
        </span>
        <span class="flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-[#22C55E] shrink-0"></span>Free forever
        </span>
        <span class="flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-[#22C55E] shrink-0"></span>Works on any device
        </span>
      </div>
    </section>

    <!-- Operation Cards -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
      <h2 class="text-2xl font-bold text-[#1E293B] mb-2 text-center">Choose an operation</h2>
      <p class="text-[#64748B] text-center mb-8 text-base">Select any topic to start practicing right away.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {operations.map((op) => (
          <a
            href={op.href}
            class="flex flex-col bg-white border border-[#E2E8F0] rounded-2xl overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 group"
          >
            <div class="px-6 py-5 min-h-[10rem] flex flex-col items-center justify-center gap-3" style={`background:${op.bg}`}>
              <div class="text-6xl font-black leading-none select-none" style={`color:${op.color}`}>
                {op.symbol}
              </div>
              <div class="text-lg font-bold text-[#1E293B] text-center">
                {op.label}
              </div>
            </div>
            <div class="px-5 py-4 flex flex-col gap-2 flex-1">
              {op.practices.map((p) => (
                <div class="flex items-center gap-2 text-sm text-[#475569]">
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${op.color}`}></span>
                  {p}
                </div>
              ))}
            </div>
            <div class="px-5 pb-5 pt-2">
              <span class="text-sm font-semibold transition-colors" style={`color:${op.color}`}>
                Practice →
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <footer class="border-t border-[#E2E8F0]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#94A3B8]">
        <a href="/addition-practice/1-digit" class="hover:text-[#64748B] transition-colors">Addition</a>
        <a href="/subtraction-practice" class="hover:text-[#64748B] transition-colors">Subtraction</a>
        <a href="/multiplication-practice" class="hover:text-[#64748B] transition-colors">Multiplication</a>
        <a href="/division-practice" class="hover:text-[#64748B] transition-colors">Division</a>
      </div>
      <p class="text-xs text-[#CBD5E1] mt-4">© {new Date().getFullYear()} Math Practice. Free arithmetic practice for students of all ages.</p>
    </div>
  </footer>
</BaseLayout>
