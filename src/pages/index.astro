---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/global.css';

const SITE = 'https://www.mathpractice.com';

const operations = [
  {
    href: '/addition/1-digit',
    label: 'Addition Practice',
    symbol: '+',
    color: '#2563EB',
    bg: '#EFF6FF',
    ring: 'rgba(37,99,235,0.35)',
    practices: ['1-Digit Addition', '2-Digit Addition', 'Addition with Carrying'],
  },
  {
    href: '/subtraction-practice',
    label: 'Subtraction Practice',
    symbol: '−',
    color: '#7C3AED',
    bg: '#F5F3FF',
    ring: 'rgba(124,58,237,0.35)',
    practices: ['1-Digit Subtraction', '2-Digit Subtraction', 'Subtraction with Borrowing'],
  },
  {
    href: '/multiplication',
    label: 'Multiplication Practice',
    symbol: '×',
    color: '#059669',
    bg: '#ECFDF5',
    ring: 'rgba(5,150,105,0.35)',
    practices: ['Multiplication Facts', 'Times Tables 1–12'],
  },
  {
    href: '/division-practice',
    label: 'Division Practice',
    symbol: '÷',
    color: '#D97706',
    bg: '#FFFBEB',
    ring: 'rgba(217,119,6,0.35)',
    practices: ['Division Facts', 'Division without Remainder', 'Division with Remainder'],
  },
];
---

<BaseLayout
  title="Math Practice — Free Arithmetic Drills for Students"
  description="Free math practice for addition, subtraction, multiplication, and division. Instant feedback and progress tracking for students in grades K–5."
  canonical={`${SITE}/`}
>
  <!-- Site Header -->
  <header class="bg-[#1E1B4B] sticky top-0 z-20 shadow-[0_1px_0_0_#312E81]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3.5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <span class="w-7 h-7 rounded-lg bg-[#4F46E5] flex items-center justify-center text-white font-black text-sm leading-none select-none group-hover:bg-[#6366F1] transition-colors">÷</span>
        <span class="text-base font-bold text-white tracking-tight">Math Practice</span>
      </a>
      <nav class="hidden sm:flex items-center gap-1">
        <a href="/addition/1-digit" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Addition</a>
        <a href="/subtraction-practice" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Subtraction</a>
        <a href="/multiplication" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Multiplication</a>
        <a href="/division-practice" class="px-3 py-1.5 rounded-lg text-sm font-medium text-[#C7D2FE] hover:text-white hover:bg-white/10 transition-all">Division</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <!-- Dark gradient background -->
      <div class="absolute inset-x-0 top-0 h-[560px] bg-gradient-to-b from-[#1E1B4B] via-[#312E81] to-[#F5F3FF]"></div>

      <!-- Ghost math symbol watermarks -->
      <div class="absolute inset-x-0 top-0 h-[560px] overflow-hidden pointer-events-none select-none" aria-hidden="true">
        <span class="absolute top-6 left-[6%] text-[130px] font-black text-white/[0.04] leading-none">+</span>
        <span class="absolute top-4 right-[5%] text-[150px] font-black text-white/[0.04] leading-none">÷</span>
        <span class="absolute top-24 left-[18%] text-[100px] font-black text-white/[0.04] leading-none">×</span>
        <span class="absolute top-16 right-[20%] text-[110px] font-black text-white/[0.04] leading-none">−</span>
      </div>

      <!-- Hero content -->
      <div class="relative max-w-2xl mx-auto px-4 sm:px-6 pt-16 pb-20 text-center">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-1.5 bg-white/10 border border-white/20 rounded-full px-4 py-1 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#34D399]"></span>
          <span class="text-xs font-semibold text-white/90 tracking-wide uppercase">Free · No login required</span>
        </div>

        <h1 class="text-5xl sm:text-6xl font-extrabold text-white leading-[1.05] tracking-tight">
          Build math skills,<br />
          <span class="text-[#A5B4FC]">one problem at a time</span>
        </h1>
        <p class="mt-5 text-lg text-white/80 max-w-lg mx-auto leading-relaxed">
          Free arithmetic practice for grades K–5. Addition, subtraction,
          multiplication, and division — with instant feedback and no pressure.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/addition/1-digit"
            class="px-6 py-3 rounded-xl bg-[#4F46E5] hover:bg-[#6366F1] text-white font-semibold text-base transition-all shadow-[0_4px_14px_rgba(79,70,229,0.5)] hover:shadow-[0_6px_20px_rgba(99,102,241,0.5)] hover:-translate-y-0.5"
          >
            Start Practicing
          </a>
        </div>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-white/55">
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#34D399]/80 shrink-0"></span>Works on any device
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#34D399]/80 shrink-0"></span>Instant feedback
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#34D399]/80 shrink-0"></span>Free forever
          </span>
        </div>
      </div>
    </section>

    <!-- Operation Cards -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-[#1E1B4B]">Choose an operation</h2>
        <p class="text-[#6B7280] mt-1 text-base">Select any topic to start practicing right away.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {operations.map((op) => (
          <a
            href={op.href}
            class="flex flex-col bg-white rounded-2xl overflow-hidden ring-1 ring-[#E0E7FF] hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-all duration-200 group"
            style={`--op-ring: ${op.ring}`}
          >
            <!-- Icon block -->
            <div class="px-6 py-7 flex flex-col items-center gap-4" style={`background:${op.bg}`}>
              <div
                class="w-16 h-16 rounded-2xl flex items-center justify-center shadow-md"
                style={`background:${op.color}`}
              >
                <span class="text-3xl font-black text-white leading-none select-none">{op.symbol}</span>
              </div>
              <div class="text-base font-bold text-[#1E1B4B] text-center leading-tight">
                {op.label}
              </div>
            </div>

            <!-- Practice list -->
            <div class="px-5 py-4 flex flex-col gap-2 flex-1 border-t border-[#E0E7FF]">
              {op.practices.map((p) => (
                <div class="flex items-center gap-2.5 text-sm text-[#4B5563]">
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${op.color}`}></span>
                  {p}
                </div>
              ))}
            </div>

            <!-- CTA row -->
            <div class="px-5 pb-5 pt-2">
              <span
                class="text-sm font-bold transition-all inline-flex items-center gap-1 group-hover:gap-2"
                style={`color:${op.color}`}
              >
                Practice <span class="transition-all">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <footer class="border-t-2 border-[#E0E7FF] bg-[#EEF2FF]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#6366F1]">
        <a href="/addition/1-digit" class="hover:text-[#3730A3] transition-colors">Addition</a>
        <a href="/subtraction-practice" class="hover:text-[#3730A3] transition-colors">Subtraction</a>
        <a href="/multiplication" class="hover:text-[#3730A3] transition-colors">Multiplication</a>
        <a href="/division-practice" class="hover:text-[#3730A3] transition-colors">Division</a>
      </div>
      <p class="text-xs text-[#A5B4FC] mt-4">© {new Date().getFullYear()} Math Practice. Free arithmetic practice for students of all ages.</p>
    </div>
  </footer>
</BaseLayout>
