---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import SubtractionPracticeHub from '@/components/SubtractionPracticeHub';
import InternalLinks from '@/components/InternalLinks';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/subtraction-practice/2-digit', label: '2-Digit Subtraction', description: 'Without borrowing focus' },
  { href: '/addition-practice/2-digit-carrying', label: 'Addition with Carrying', description: 'Related skill' },
  { href: '/subtraction-practice', label: 'All Subtraction Practice', description: 'See all levels' },
];
---

<PracticeLayout
  title="Subtraction with Borrowing Practice | Math Practice"
  description="Targeted practice for two-digit subtraction with borrowing and regrouping. Every problem requires borrowing. Timed and untimed modes."
  canonical={`${SITE}/subtraction-practice/2-digit-borrowing`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Subtraction Practice', href: '/subtraction-practice' }, { label: 'Subtraction with Borrowing' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Subtraction with Borrowing Practice</h1>
  <SubtractionPracticeHub slot="widget" active="borrowing" client:load />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
