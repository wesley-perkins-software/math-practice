---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import SubtractionPracticeHub from '@/components/SubtractionPracticeHub';

const SITE = 'https://www.mathpracticeonline.com';
---

<PracticeLayout
  title="Subtraction Practice — Free Online Subtraction Drills"
  description="Practice subtraction online with instant feedback. 1-digit through 2-digit subtraction, with and without borrowing. Timed and untimed modes."
  canonical={`${SITE}/subtraction-practice`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Subtraction Practice' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Subtraction Practice</h1>
  <SubtractionPracticeHub slot="widget" active="1-digit" client:load />

  <div slot="links" class="mt-10">
    <h2 class="text-base font-semibold text-[#1E293B] mb-3">What to Practice Next</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a
        href="/addition-practice"
        class="block bg-white border border-[#E2E8F0] rounded-xl p-4 hover:border-[#3B82F6] hover:shadow-sm transition-all"
      >
        <div class="font-semibold text-[#1E293B]">Addition Practice</div>
        <div class="text-sm text-[#64748B] mt-0.5">Practice the inverse operation</div>
      </a>
      <a
        href="/arithmetic-speed-drill"
        class="block bg-white border border-[#E2E8F0] rounded-xl p-4 hover:border-[#3B82F6] hover:shadow-sm transition-all"
      >
        <div class="font-semibold text-[#1E293B]">Arithmetic Speed Drill</div>
        <div class="text-sm text-[#64748B] mt-0.5">Mixed operations, timed challenge</div>
      </a>
    </div>
  </div>
</PracticeLayout>
