---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { SUBTRACTION_2_DIGIT } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/subtraction-practice/1-digit', label: '1-Digit Subtraction', description: 'Easier — start here' },
  { href: '/subtraction-practice/2-digit-borrowing', label: 'Subtraction with Borrowing', description: 'Harder — add borrowing' },
  { href: '/addition-practice/2-digit', label: '2-Digit Addition', description: 'Practice the inverse' },
  { href: '/subtraction-practice', label: 'All Subtraction Practice', description: 'See all levels' },
];
---

<PracticeLayout
  title="2-Digit Subtraction Practice | Math Practice"
  description="Practice two-digit subtraction online. Numbers from 10 to 99, may include borrowing. Timed and untimed modes with instant feedback."
  canonical={`${SITE}/subtraction-practice/2-digit`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Subtraction Practice', href: '/subtraction-practice' }, { label: '2-Digit Subtraction' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">2-Digit Subtraction Practice</h1>
  <div slot="intro">
    <p>Practice two-digit subtraction with numbers from 10 to 99. Problems may include borrowing, making this a good all-around two-digit subtraction workout.</p>
  </div>
  <PracticeWidget slot="widget" client:load config={SUBTRACTION_2_DIGIT} />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
