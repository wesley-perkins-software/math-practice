---
import PracticeLayout from '@/layouts/PracticeLayout.astro';
import PracticeWidget from '@/components/PracticeWidget';
import InternalLinks from '@/components/InternalLinks';
import { MATH_PRACTICE_GENERAL } from '@/engine/presets';

const SITE = 'https://www.mathpractice.com';

const links = [
  { href: '/addition-practice', label: 'Addition Practice', description: 'Focus on addition' },
  { href: '/subtraction', label: 'Subtraction Practice', description: 'Focus on subtraction' },
  { href: '/multiplication', label: 'Multiplication Practice', description: 'Times tables and more' },
  { href: '/division', label: 'Division Practice', description: 'Division facts and remainders' },
  { href: '/arithmetic-speed-drill', label: 'Arithmetic Speed Drill', description: 'Timed mixed facts' },
];
---

<PracticeLayout
  title="Math Practice — Mixed Arithmetic Problems Online"
  description="Free mixed arithmetic practice for all four operations. Addition, subtraction, multiplication, and division in one session. Timed and untimed modes."
  canonical={`${SITE}/math-practice`}
  breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Math Practice' }]}
>
  <h1 slot="h1" class="text-3xl font-bold text-[#1E293B]">Math Practice</h1>
  <div slot="intro">
    <p>Practice all four arithmetic operations — addition, subtraction, multiplication, and division — in a single mixed session. A well-rounded drill for students who want broad fluency.</p>
  </div>
  <PracticeWidget slot="widget" client:load config={MATH_PRACTICE_GENERAL} />
  <InternalLinks slot="links" links={links} />
</PracticeLayout>
